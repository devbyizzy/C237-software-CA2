<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect - Student Finder</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="navbar">
    <div class="navbar-left">
      <button class="hamburger" id="hamburgerBtn" type="button" aria-label="Toggle menu">☰</button>
      <a href="/" class="logo">🎓 RPConnect</a>
    </div>

    <form class="navbar-search" action="#" method="GET" onsubmit="return false;">
      <span class="search-icon">🔍</span>
      <input type="text" name="q" placeholder="Search students, questions, groups..." />
    </form>

    <div class="navbar-right">
      <button class="btn btn-primary create-btn" type="button">+ Create</button>

      <button class="icon-btn notif-btn" type="button" aria-label="Notifications" title="Notifications">
        🔔
        <span class="notif-dot" id="notifDot" hidden></span>
      </button>

      <div class="navbar-profile dropdown">
        <button class="navbar-profile-trigger" id="profileMenuBtn" type="button">
          <div class="avatar avatar-sm" id="navAvatar">
            <%= user && user.name
              ? user.name.charAt(0).toUpperCase()
              : "U"
            %>
          </div>
          <span class="navbar-username" id="navUsername">
            <%= user && user.username
              ? user.username
              : user && user.name
                ? user.name
                : "User"
            %>
          </span>
          <span class="caret">▾</span>
        </button>
        <div class="dropdown-menu" id="profileMenu">
          <a href="/profile" class="dropdown-item">🙍 My Profile</a>
          <a href="/profile" class="dropdown-item">⚙️ Settings</a>
          <form action="/logout" method="POST" class="logout-form">
            <button type="submit" class="dropdown-item logout-item">
              🚪 Logout
            </button>
          </form>
        </div>
      </div>
    </div>
  </header>

  <div class="layout layout-2col">
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">
        <a href="/" class="sidebar-link">
          <span class="sidebar-icon">🏠</span> Home
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">❓</span> Questions
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">👥</span> Groups
        </a>
        <a href="/ccas" class="sidebar-link">
          <span class="sidebar-icon">🎭</span> CCAs
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">🗓️</span> Timetables
        </a>
        <a href="/students" class="sidebar-link active">
          <span class="sidebar-icon">🔎</span> Student Finder
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">📌</span> My Groups
        </a>
        <a href="/profile" class="sidebar-link">
          <span class="sidebar-icon">🙍</span> My Profile
        </a>
      </nav>
    </aside>

    <main class="feed">
      <h1 class="feed-title">Student Finder</h1>

      <section class="feed-section">
        <div class="card">
          <form id="searchForm" class="search-filters">
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="diplomaInput">Diploma</label>
              <input class="form-input" type="text" id="diplomaInput" name="diploma" placeholder="e.g. Information Technology" />
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="classInput">Class</label>
              <input class="form-input" type="text" id="classInput" name="class_code" placeholder="e.g. IT-01" />
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="interestInput">Interest</label>
              <input class="form-input" type="text" id="interestInput" name="interest" placeholder="e.g. Robotics" />
            </div>
            <div class="form-actions" style="margin-top:0;">
              <button type="submit" class="btn btn-primary">Search</button>
              <button type="button" id="clearFiltersBtn" class="btn btn-outline">Clear</button>
            </div>
          </form>
        </div>
      </section>

      <section class="feed-section">
        <p class="results-count" id="resultsCount"></p>
        <div class="search-results-grid" id="studentResults"></div>
      </section>
    </main>
  </div>

  <script src="/js/config.js"></script>
  <script src="/js/nav.js"></script>
  <script src="/js/students.js"></script>
</body>
</html>