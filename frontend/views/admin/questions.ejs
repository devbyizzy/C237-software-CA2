<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect Admin - Questions</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-page">
  <a class="admin-skip-link" href="#adminMain">Skip to question moderation</a>

  <%- include("partials/header", { user: user }) %>

  <%
    const moderationAvailable =
      typeof available === "undefined" ? true : available === true;
    const adminQuestions =
      typeof questions !== "undefined" && Array.isArray(questions) ? questions : [];
    const activeFilters =
      typeof filters !== "undefined" && filters && typeof filters === "object"
        ? filters
        : {};
    const statusOptions = (
      typeof statuses !== "undefined" && Array.isArray(statuses)
        ? statuses
        : ["open", "resolved"]
    ).filter(function (status) {
      return typeof status === "string" && status.length > 0;
    });
    const safeCsrfToken =
      typeof csrfToken === "string" ? csrfToken : "";
    const noticeMessage =
      typeof notice !== "undefined" && notice && typeof notice === "object"
        ? notice.message
        : typeof notice !== "undefined"
          ? notice
          : null;
    const noticeType =
      typeof notice !== "undefined" &&
      notice &&
      typeof notice === "object" &&
      notice.type === "success"
        ? "success"
        : "error";

    function formatAdminDate(value) {
      if (!value) {
        return "Not available";
      }

      const date = new Date(value);
      if (Number.isNaN(date.getTime())) {
        return "Not available";
      }

      return new Intl.DateTimeFormat("en-SG", {
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit"
      }).format(date);
    }

    function adminDateTime(value) {
      if (!value) {
        return "";
      }

      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? "" : date.toISOString();
    }
  %>

  <div class="layout admin-layout">
    <%- include("partials/sidebar", {
      activePage: "questions",
      csrfToken: safeCsrfToken
    }) %>

    <main class="admin-main" id="adminMain">
      <div class="admin-page-header">
        <div>
          <p class="admin-eyebrow">Community moderation</p>
          <h1 class="admin-page-title">Question Moderation</h1>
          <p class="admin-page-subtitle">
            Review student questions, update resolution status, and remove inappropriate content.
          </p>
        </div>

        <% if (moderationAvailable) { %>
          <div class="admin-count-chip">
            <strong><%= adminQuestions.length %></strong>
            <span><%= adminQuestions.length === 1 ? "result" : "results" %></span>
          </div>
        <% } %>
      </div>

      <% if (noticeMessage) { %>
        <div
          class="admin-notice admin-notice--<%= noticeType %>"
          role="<%= noticeType === "success" ? "status" : "alert" %>"
        >
          <span class="admin-notice-icon" aria-hidden="true">
            <%= noticeType === "success" ? "✓" : "!" %>
          </span>
          <p><%= noticeMessage %></p>
        </div>
      <% } %>

      <% if (!moderationAvailable) { %>
        <section class="admin-panel" aria-labelledby="questionsUnavailableTitle">
          <div class="admin-empty-state admin-empty-state--large">
            <span class="admin-empty-icon" aria-hidden="true">?</span>
            <h2 id="questionsUnavailableTitle">Question moderation is unavailable</h2>
            <p>
              The question tables are not installed in this database yet.
              Install the provided migration before using moderation tools.
            </p>
            <a href="/admin" class="btn btn-outline">Back to dashboard</a>
          </div>
        </section>
      <% } else { %>
        <section class="admin-panel admin-filter-panel" aria-labelledby="questionFiltersTitle">
          <div class="admin-panel-header admin-panel-header--compact">
            <div>
              <p class="admin-eyebrow">Find content</p>
              <h2 class="admin-panel-title" id="questionFiltersTitle">Search and filter</h2>
            </div>
          </div>

          <form
            action="/admin/questions"
            method="GET"
            class="admin-filter-form admin-filter-form--three"
          >
            <div class="form-group admin-form-group">
              <label class="form-label" for="questionSearch">Question or user</label>
              <input
                class="form-input"
                id="questionSearch"
                name="search"
                type="search"
                value="<%= activeFilters.search || "" %>"
                placeholder="Search title, content, or user"
                maxlength="200"
                autocomplete="off"
              />
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="questionStatusFilter">Status</label>
              <select
                class="form-input admin-select"
                id="questionStatusFilter"
                name="status"
              >
                <option value="">All statuses</option>
                <% statusOptions.forEach(function (status) { %>
                  <option value="<%= status %>" <%= activeFilters.status === status ? "selected" : "" %>>
                    <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                  </option>
                <% }); %>
              </select>
            </div>

            <div class="admin-filter-actions">
              <button type="submit" class="btn btn-primary">Apply filters</button>
              <a href="/admin/questions" class="btn btn-outline">Clear</a>
            </div>
          </form>
        </section>

        <section class="admin-panel" aria-labelledby="questionsTableTitle">
          <div class="admin-panel-header">
            <div>
              <p class="admin-eyebrow">Moderation queue</p>
              <h2 class="admin-panel-title" id="questionsTableTitle">Questions</h2>
            </div>
            <p class="admin-results-summary">
              Showing <strong><%= adminQuestions.length %></strong>
              <%= adminQuestions.length === 1 ? "question" : "questions" %>
            </p>
          </div>

          <% if (adminQuestions.length > 0) { %>
            <div
              class="admin-table-wrap"
              role="region"
              aria-labelledby="questionsTableTitle"
              tabindex="0"
            >
              <table class="admin-table admin-questions-table">
                <caption class="admin-visually-hidden">
                  Questions matching the current moderation filters
                </caption>
                <thead>
                  <tr>
                    <th scope="col">Question</th>
                    <th scope="col">Author</th>
                    <th scope="col">Category</th>
                    <th scope="col">Status</th>
                    <th scope="col">Replies</th>
                    <th scope="col">Created</th>
                    <th scope="col"><span class="admin-visually-hidden">Actions</span></th>
                  </tr>
                </thead>
                <tbody>
                  <% adminQuestions.forEach(function (question) { %>
                    <%
                      const questionId =
                        question.question_id !== undefined
                          ? question.question_id
                          : question.questionId;
                      const status =
                        typeof question.status === "string" &&
                        question.status.toLowerCase() === "resolved"
                          ? "resolved"
                          : "open";
                      const replyCount = Number(
                        question.reply_count !== undefined
                          ? question.reply_count
                          : question.replyCount
                      );
                      const createdAt =
                        question.created_at !== undefined
                          ? question.created_at
                          : question.createdAt;
                    %>
                    <tr>
                      <td>
                        <span class="admin-user-primary">
                          <%= question.title || "Untitled question" %>
                        </span>
                        <% if (question.content) { %>
                          <span class="admin-secondary-line admin-clamp-text">
                            <%= question.content %>
                          </span>
                        <% } %>
                      </td>
                      <td>
                        <span class="admin-user-primary">
                          <%= question.author_username || question.username || question.name || "Unknown user" %>
                        </span>
                        <% if (question.author_email || question.email) { %>
                          <span class="admin-secondary-line admin-break-value">
                            <%= question.author_email || question.email %>
                          </span>
                        <% } %>
                      </td>
                      <td><%= question.category || "Not assigned" %></td>
                      <td>
                        <span class="admin-status-badge admin-status-badge--<%= status %>">
                          <span class="admin-status-dot" aria-hidden="true"></span>
                          <%= status === "resolved" ? "Resolved" : "Open" %>
                        </span>
                      </td>
                      <td><%= Number.isFinite(replyCount) ? replyCount : 0 %></td>
                      <td>
                        <time datetime="<%= adminDateTime(createdAt) %>">
                          <%= formatAdminDate(createdAt) %>
                        </time>
                      </td>
                      <td class="admin-table-action">
                        <a
                          class="btn btn-outline admin-table-button"
                          href="/admin/questions/<%= encodeURIComponent(String(questionId)) %>"
                          aria-label="Review <%= question.title || "question" %>"
                        >
                          Review
                        </a>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="admin-empty-state">
              <span class="admin-empty-icon" aria-hidden="true">&#128269;</span>
              <h3>No matching questions</h3>
              <p>Try clearing one or more moderation filters.</p>
              <a href="/admin/questions" class="btn btn-outline">Clear filters</a>
            </div>
          <% } %>
        </section>
      <% } %>
    </main>
  </div>

  <script src="/js/nav.js"></script>
</body>
</html>
