<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect Admin - RP Circle Details</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-page">
  <a class="admin-skip-link" href="#adminMain">Skip to RP Circle details</a>

  <%- include("partials/header", { user: user }) %>

  <%
    const circle =
      typeof group !== "undefined" && group && typeof group === "object"
        ? group
        : {};
    const groupId =
      circle.group_id !== undefined ? circle.group_id : circle.groupId;
    const createdAt =
      circle.created_at !== undefined ? circle.created_at : circle.createdAt;
    const memberCount = Number(
      circle.member_count !== undefined ? circle.member_count : circle.memberCount
    );
    const pendingCount = Number(
      circle.pending_count !== undefined ? circle.pending_count : circle.pendingCount
    );
    const circleMembers =
      Array.isArray(circle.members) ? circle.members : [];
    const postCount = Number(
      circle.post_count !== undefined ? circle.post_count : circle.postCount
    );
    const replyCount = Number(
      circle.reply_count !== undefined ? circle.reply_count : circle.replyCount
    );
    const safeCsrfToken =
      typeof csrfToken === "string" ? csrfToken : "";
    const noticeMessage =
      typeof notice !== "undefined" && notice && typeof notice === "object"
        ? notice.message
        : typeof notice !== "undefined"
          ? notice
          : null;
    const noticeType =
      typeof notice !== "undefined" &&
      notice &&
      typeof notice === "object" &&
      notice.type === "success"
        ? "success"
        : "error";

    function displayAdminValue(value) {
      return value === undefined || value === null || value === ""
        ? "Not provided"
        : value;
    }

    function formatAdminDate(value) {
      if (!value) {
        return "Not available";
      }

      const date = new Date(value);
      if (Number.isNaN(date.getTime())) {
        return "Not available";
      }

      return new Intl.DateTimeFormat("en-SG", {
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit"
      }).format(date);
    }

    function adminDateTime(value) {
      if (!value) {
        return "";
      }

      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? "" : date.toISOString();
    }
  %>

  <div class="layout admin-layout">
    <%- include("partials/sidebar", {
      activePage: "groups",
      csrfToken: safeCsrfToken
    }) %>

    <main class="admin-main" id="adminMain">
      <nav class="admin-breadcrumbs" aria-label="Breadcrumb">
        <a href="/admin">Dashboard</a>
        <span aria-hidden="true">/</span>
        <a href="/admin/groups">RP Circles</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">
          <%= circle.group_name || circle.groupName || "Circle details" %>
        </span>
      </nav>

      <div class="admin-page-header admin-user-heading">
        <div class="admin-user-heading-main">
          <div class="avatar admin-detail-avatar" aria-hidden="true">
            <%= circle.group_name || circle.groupName
              ? String(circle.group_name || circle.groupName).charAt(0).toUpperCase()
              : "G"
            %>
          </div>
          <div>
            <p class="admin-eyebrow">RP Circle #<%= groupId %></p>
            <h1 class="admin-page-title">
              <%= circle.group_name || circle.groupName || "Unnamed circle" %>
            </h1>
            <p class="admin-page-subtitle">
              Created by
              <%= circle.creator_name || circle.creator_username || "an unknown user" %>
            </p>
          </div>
        </div>

        <div class="admin-heading-badges" aria-label="Circle type and privacy">
          <span class="admin-role-badge admin-role-badge--large">
            <%= circle.group_type || circle.groupType || "No type" %>
          </span>
          <span class="admin-status-badge admin-status-badge--neutral">
            <%= circle.privacy === "private" ? "Private" : "Public" %>
          </span>
        </div>
      </div>

      <% if (noticeMessage) { %>
        <div
          class="admin-notice admin-notice--<%= noticeType %>"
          role="<%= noticeType === "success" ? "status" : "alert" %>"
        >
          <span class="admin-notice-icon" aria-hidden="true">
            <%= noticeType === "success" ? "✓" : "!" %>
          </span>
          <p><%= noticeMessage %></p>
        </div>
      <% } %>

      <div class="admin-detail-columns">
        <section class="admin-panel" aria-labelledby="circleInformationTitle">
          <div class="admin-panel-header">
            <div>
              <p class="admin-eyebrow">Circle record</p>
              <h2 class="admin-panel-title" id="circleInformationTitle">Circle information</h2>
            </div>
          </div>

          <dl class="admin-definition-grid">
            <div class="admin-definition-item">
              <dt>Circle ID</dt>
              <dd><span class="admin-id-chip">#<%= groupId %></span></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Accepted members</dt>
              <dd><%= Number.isFinite(memberCount) ? memberCount : 0 %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Pending requests</dt>
              <dd><%= Number.isFinite(pendingCount) ? pendingCount : 0 %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Type</dt>
              <dd><%= displayAdminValue(circle.group_type || circle.groupType) %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Privacy</dt>
              <dd><%= circle.privacy === "private" ? "Private" : "Public" %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Maximum members</dt>
              <dd><%= displayAdminValue(circle.max_members || circle.maxMembers) %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Created</dt>
              <dd>
                <time datetime="<%= adminDateTime(createdAt) %>">
                  <%= formatAdminDate(createdAt) %>
                </time>
              </dd>
            </div>
            <div class="admin-definition-item admin-definition-item--wide">
              <dt>Description</dt>
              <dd><%= displayAdminValue(circle.description) %></dd>
            </div>
          </dl>
        </section>

        <section class="admin-panel" aria-labelledby="circleContextTitle">
          <div class="admin-panel-header">
            <div>
              <p class="admin-eyebrow">Student context</p>
              <h2 class="admin-panel-title" id="circleContextTitle">Academic and owner details</h2>
            </div>
          </div>

          <dl class="admin-definition-grid">
            <div class="admin-definition-item">
              <dt>Creator</dt>
              <dd><%= displayAdminValue(circle.creator_name || circle.creator_username) %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Creator email</dt>
              <dd class="admin-break-value"><%= displayAdminValue(circle.creator_email) %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Diploma</dt>
              <dd><%= displayAdminValue(circle.diploma) %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Class</dt>
              <dd><%= displayAdminValue(circle.class_code || circle.classCode) %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Module</dt>
              <dd><%= displayAdminValue(circle.module_code || circle.moduleCode) %></dd>
            </div>
            <div class="admin-definition-item">
              <dt>Year / semester</dt>
              <dd>
                <%= displayAdminValue(circle.year_of_study || circle.yearOfStudy) %>
                /
                <%= displayAdminValue(circle.semester) %>
              </dd>
            </div>
          </dl>
        </section>
      </div>

      <section class="admin-panel" aria-labelledby="circleContentTitle">
        <div class="admin-panel-header">
          <div>
            <p class="admin-eyebrow">Dependent content</p>
            <h2 class="admin-panel-title" id="circleContentTitle">Content summary</h2>
          </div>
        </div>
        <div class="admin-summary-grid">
          <div class="admin-summary-item">
            <strong><%= Number.isFinite(memberCount) ? memberCount : 0 %></strong>
            <span>Accepted members</span>
          </div>
          <div class="admin-summary-item">
            <strong><%= Number.isFinite(pendingCount) ? pendingCount : 0 %></strong>
            <span>Pending requests</span>
          </div>
          <div class="admin-summary-item">
            <strong><%= Number.isFinite(postCount) ? postCount : 0 %></strong>
            <span>Group posts</span>
          </div>
          <div class="admin-summary-item">
            <strong><%= Number.isFinite(replyCount) ? replyCount : 0 %></strong>
            <span>Post replies</span>
          </div>
        </div>
      </section>

      <section class="admin-panel" aria-labelledby="circleMembersTitle">
        <div class="admin-panel-header">
          <div>
            <p class="admin-eyebrow">Membership records</p>
            <h2 class="admin-panel-title" id="circleMembersTitle">Members and join requests</h2>
          </div>
          <p class="admin-results-summary">
            <strong><%= circleMembers.length %></strong>
            <%= circleMembers.length === 1 ? "record" : "records" %>
          </p>
        </div>

        <% if (circleMembers.length > 0) { %>
          <div class="admin-table-wrap" tabindex="0" aria-label="Circle membership records">
            <table class="admin-table">
              <thead>
                <tr>
                  <th scope="col">User</th>
                  <th scope="col">Member role</th>
                  <th scope="col">Join status</th>
                  <th scope="col">Joined</th>
                  <th scope="col"><span class="admin-visually-hidden">Actions</span></th>
                </tr>
              </thead>
              <tbody>
                <% circleMembers.forEach(function (member) { %>
                  <tr>
                    <td>
                      <span class="admin-user-primary">
                        <%= member.display_name || member.username || "Unknown user" %>
                      </span>
                      <span class="admin-secondary-line admin-break-value">
                        <%= member.email || "Email unavailable" %>
                      </span>
                    </td>
                    <td><%= displayAdminValue(member.member_role) %></td>
                    <td>
                      <span class="admin-status-badge admin-status-badge--neutral">
                        <%= displayAdminValue(member.join_status) %>
                      </span>
                    </td>
                    <td>
                      <time datetime="<%= adminDateTime(member.joined_at) %>">
                        <%= formatAdminDate(member.joined_at) %>
                      </time>
                    </td>
                    <td class="admin-table-action">
                      <a
                        class="btn btn-outline admin-table-button"
                        href="/admin/users/<%= encodeURIComponent(String(member.user_id)) %>"
                      >
                        View user
                      </a>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="admin-empty-state admin-empty-state--compact">
            <h3>No membership records</h3>
            <p>This circle currently has no members or pending join requests.</p>
          </div>
        <% } %>
      </section>

      <section class="admin-danger-panel" aria-labelledby="deleteCircleTitle">
        <div class="admin-danger-copy">
          <p class="admin-eyebrow admin-eyebrow--danger">Permanent moderation action</p>
          <h2 id="deleteCircleTitle">Delete RP Circle</h2>
          <p>
            Deleting this circle also removes its memberships, join requests,
            posts, and replies. This cannot be undone.
          </p>
        </div>

        <form
          action="/admin/groups/<%= encodeURIComponent(String(groupId)) %>/delete"
          method="POST"
          class="admin-reset-form"
        >
          <input type="hidden" name="_csrf" value="<%= safeCsrfToken %>" />

          <label class="admin-confirm-control" for="confirmDeleteGroup">
            <input
              id="confirmDeleteGroup"
              type="checkbox"
              name="confirmDelete"
              value="yes"
              required
            />
            <span>
              I confirm that I am permanently deleting
              <strong><%= circle.group_name || circle.groupName || "this circle" %></strong>.
            </span>
          </label>

          <button type="submit" class="admin-danger-button">Delete circle permanently</button>
        </form>
      </section>

      <div class="admin-page-footer-action">
        <a href="/admin/groups" class="btn btn-outline">Back to RP Circles</a>
      </div>
    </main>
  </div>

  <script src="/js/nav.js"></script>
</body>
</html>
