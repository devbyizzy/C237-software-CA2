<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect Admin - <%= typeof mode === "string" && mode === "edit" ? "Edit" : "Create" %> CCA</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-page">
  <a class="admin-skip-link" href="#adminMain">Skip to CCA form</a>

  <%- include("partials/header", { user: user }) %>

  <%
    const isEditMode =
      typeof mode === "string" && mode.toLowerCase() === "edit";
    const ccaRecord =
      typeof cca !== "undefined" && cca && typeof cca === "object"
        ? cca
        : {};
    const submittedValues =
      typeof formData !== "undefined" &&
      formData &&
      typeof formData === "object"
        ? formData
        : {};
    const values = Object.assign({}, ccaRecord, submittedValues);
    const errors =
      typeof fieldErrors !== "undefined" && fieldErrors
        ? fieldErrors
        : {};
    const safeCsrfToken =
      typeof csrfToken === "string" ? csrfToken : "";
    const ccaId =
      values.cca_id !== undefined ? values.cca_id : values.ccaId;
    const categoryOptions = (
      typeof categories !== "undefined" && Array.isArray(categories)
        ? categories
        : ["Technology", "Arts", "Sports", "Student Life"]
    ).filter(function (category) {
      return typeof category === "string" && category.length > 0;
    });
    const statusOptions = (
      typeof statuses !== "undefined" && Array.isArray(statuses)
        ? statuses
        : ["active", "inactive"]
    ).filter(function (status) {
      return typeof status === "string" && status.length > 0;
    });
    const noticeMessage =
      typeof notice !== "undefined" && notice && typeof notice === "object"
        ? notice.message
        : typeof notice !== "undefined"
          ? notice
          : null;
    const noticeType =
      typeof notice !== "undefined" &&
      notice &&
      typeof notice === "object" &&
      notice.type === "success"
        ? "success"
        : "error";

    function fieldValue() {
      const names = Array.prototype.slice.call(arguments);
      for (let index = 0; index < names.length; index += 1) {
        const value = values[names[index]];
        if (value !== undefined && value !== null) {
          return value;
        }
      }
      return "";
    }

    function fieldError(name) {
      if (!errors || Array.isArray(errors) || typeof errors !== "object") {
        return "";
      }

      const error = errors[name];
      if (Array.isArray(error)) {
        return error.filter(Boolean).join(" ");
      }

      return typeof error === "string" ? error : "";
    }

    function timeInputValue(value) {
      if (!value) {
        return "";
      }

      const match = String(value).match(/^(\d{1,2}):(\d{2})/);
      return match
        ? `${match[1].padStart(2, "0")}:${match[2]}`
        : "";
    }

    const errorMessages = Array.isArray(errors)
      ? errors.filter(function (error) {
          return typeof error === "string" && error.length > 0;
        })
      : Object.keys(errors).reduce(function (messages, key) {
          const value = errors[key];
          if (Array.isArray(value)) {
            return messages.concat(value.filter(Boolean));
          }
          if (typeof value === "string" && value.length > 0) {
            messages.push(value);
          }
          return messages;
        }, []);
    const currentCategory = String(fieldValue("category") || "");
    const currentStatus = String(fieldValue("status") || "active").toLowerCase();
    const formAction = isEditMode
      ? `/admin/ccas/${encodeURIComponent(String(ccaId))}/edit`
      : "/admin/ccas";
  %>

  <div class="layout admin-layout">
    <%- include("partials/sidebar", {
      activePage: "ccas",
      csrfToken: safeCsrfToken
    }) %>

    <main class="admin-main" id="adminMain">
      <nav class="admin-breadcrumbs" aria-label="Breadcrumb">
        <a href="/admin">Dashboard</a>
        <span aria-hidden="true">/</span>
        <a href="/admin/ccas">CCAs</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page"><%= isEditMode ? "Edit CCA" : "Create CCA" %></span>
      </nav>

      <div class="admin-page-header">
        <div>
          <p class="admin-eyebrow"><%= isEditMode ? `CCA #${ccaId}` : "New directory entry" %></p>
          <h1 class="admin-page-title"><%= isEditMode ? "Edit CCA" : "Create CCA" %></h1>
          <p class="admin-page-subtitle">
            <%= isEditMode
              ? "Update this CCA's directory information and availability."
              : "Add a co-curricular activity to the RPConnect directory."
            %>
          </p>
        </div>
      </div>

      <% if (noticeMessage) { %>
        <div
          class="admin-notice admin-notice--<%= noticeType %>"
          role="<%= noticeType === "success" ? "status" : "alert" %>"
        >
          <span class="admin-notice-icon" aria-hidden="true">
            <%= noticeType === "success" ? "✓" : "!" %>
          </span>
          <p><%= noticeMessage %></p>
        </div>
      <% } %>

      <% if (errorMessages.length > 0) { %>
        <div class="admin-form-errors" role="alert" aria-labelledby="ccaFormErrorsTitle">
          <h2 id="ccaFormErrorsTitle">Please correct the following:</h2>
          <ul>
            <% errorMessages.forEach(function (message) { %>
              <li><%= message %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <section class="admin-panel" aria-labelledby="ccaFormTitle">
        <div class="admin-panel-header">
          <div>
            <p class="admin-eyebrow">Directory information</p>
            <h2 class="admin-panel-title" id="ccaFormTitle">CCA details</h2>
          </div>
          <span class="admin-required-note"><span aria-hidden="true">*</span> Required fields</span>
        </div>

        <form action="<%= formAction %>" method="POST" class="admin-record-form">
          <input type="hidden" name="_csrf" value="<%= safeCsrfToken %>" />

          <div class="admin-form-grid">
            <div class="form-group admin-form-group admin-form-field--wide">
              <label class="form-label" for="ccaName">
                CCA name <span class="admin-required-mark" aria-hidden="true">*</span>
              </label>
              <input
                class="form-input"
                id="ccaName"
                name="cca_name"
                type="text"
                value="<%= fieldValue("cca_name", "ccaName") %>"
                maxlength="150"
                required
                <% if (fieldError("cca_name")) { %>
                  aria-invalid="true"
                  aria-describedby="ccaNameError"
                <% } %>
              />
              <% if (fieldError("cca_name")) { %>
                <p class="admin-field-error" id="ccaNameError"><%= fieldError("cca_name") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="ccaCategory">
                Category <span class="admin-required-mark" aria-hidden="true">*</span>
              </label>
              <select
                class="form-input admin-select"
                id="ccaCategory"
                name="category"
                required
                <% if (fieldError("category")) { %>
                  aria-invalid="true"
                  aria-describedby="ccaCategoryError"
                <% } %>
              >
                <option value="">Select a category</option>
                <% if (currentCategory && !categoryOptions.includes(currentCategory)) { %>
                  <option value="<%= currentCategory %>" selected><%= currentCategory %></option>
                <% } %>
                <% categoryOptions.forEach(function (category) { %>
                  <option value="<%= category %>" <%= currentCategory === category ? "selected" : "" %>>
                    <%= category %>
                  </option>
                <% }); %>
              </select>
              <% if (fieldError("category")) { %>
                <p class="admin-field-error" id="ccaCategoryError"><%= fieldError("category") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="ccaStatus">
                Status <span class="admin-required-mark" aria-hidden="true">*</span>
              </label>
              <select
                class="form-input admin-select"
                id="ccaStatus"
                name="status"
                required
                <% if (fieldError("status")) { %>
                  aria-invalid="true"
                  aria-describedby="ccaStatusError"
                <% } %>
              >
                <% statusOptions.forEach(function (status) { %>
                  <option value="<%= status %>" <%= currentStatus === status.toLowerCase() ? "selected" : "" %>>
                    <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                  </option>
                <% }); %>
              </select>
              <% if (fieldError("status")) { %>
                <p class="admin-field-error" id="ccaStatusError"><%= fieldError("status") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group admin-form-field--wide">
              <label class="form-label" for="ccaDescription">Description</label>
              <textarea
                class="form-textarea"
                id="ccaDescription"
                name="description"
                rows="5"
                maxlength="5000"
                <% if (fieldError("description")) { %>
                  aria-invalid="true"
                  aria-describedby="ccaDescriptionError"
                <% } %>
              ><%= fieldValue("description") %></textarea>
              <% if (fieldError("description")) { %>
                <p class="admin-field-error" id="ccaDescriptionError"><%= fieldError("description") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="meetingDay">Meeting day</label>
              <input
                class="form-input"
                id="meetingDay"
                name="meeting_day"
                type="text"
                value="<%= fieldValue("meeting_day", "meetingDay") %>"
                maxlength="30"
                placeholder="e.g. Wednesday"
                <% if (fieldError("meeting_day")) { %>
                  aria-invalid="true"
                  aria-describedby="meetingDayError"
                <% } %>
              />
              <% if (fieldError("meeting_day")) { %>
                <p class="admin-field-error" id="meetingDayError"><%= fieldError("meeting_day") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="meetingStartTime">Start time</label>
              <input
                class="form-input"
                id="meetingStartTime"
                name="meeting_start_time"
                type="time"
                value="<%= timeInputValue(fieldValue("meeting_start_time", "meetingStartTime")) %>"
                <% if (fieldError("meeting_start_time")) { %>
                  aria-invalid="true"
                  aria-describedby="meetingStartTimeError"
                <% } %>
              />
              <% if (fieldError("meeting_start_time")) { %>
                <p class="admin-field-error" id="meetingStartTimeError"><%= fieldError("meeting_start_time") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="meetingEndTime">End time</label>
              <input
                class="form-input"
                id="meetingEndTime"
                name="meeting_end_time"
                type="time"
                value="<%= timeInputValue(fieldValue("meeting_end_time", "meetingEndTime")) %>"
                <% if (fieldError("meeting_end_time")) { %>
                  aria-invalid="true"
                  aria-describedby="meetingEndTimeError"
                <% } %>
              />
              <% if (fieldError("meeting_end_time")) { %>
                <p class="admin-field-error" id="meetingEndTimeError"><%= fieldError("meeting_end_time") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="ccaLocation">Location</label>
              <input
                class="form-input"
                id="ccaLocation"
                name="location"
                type="text"
                value="<%= fieldValue("location") %>"
                maxlength="150"
                <% if (fieldError("location")) { %>
                  aria-invalid="true"
                  aria-describedby="ccaLocationError"
                <% } %>
              />
              <% if (fieldError("location")) { %>
                <p class="admin-field-error" id="ccaLocationError"><%= fieldError("location") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="contactEmail">Contact email</label>
              <input
                class="form-input"
                id="contactEmail"
                name="contact_email"
                type="email"
                value="<%= fieldValue("contact_email", "contactEmail") %>"
                maxlength="150"
                autocomplete="email"
                <% if (fieldError("contact_email")) { %>
                  aria-invalid="true"
                  aria-describedby="contactEmailError"
                <% } %>
              />
              <% if (fieldError("contact_email")) { %>
                <p class="admin-field-error" id="contactEmailError"><%= fieldError("contact_email") %></p>
              <% } %>
            </div>

            <div class="form-group admin-form-group admin-form-field--wide">
              <label class="form-label" for="ccaImageUrl">Image URL</label>
              <input
                class="form-input"
                id="ccaImageUrl"
                name="image_url"
                type="url"
                value="<%= fieldValue("image_url", "imageUrl") %>"
                maxlength="255"
                placeholder="https://example.com/image.jpg"
                <% if (fieldError("image_url")) { %>
                  aria-invalid="true"
                  aria-describedby="ccaImageUrlError"
                <% } %>
              />
              <% if (fieldError("image_url")) { %>
                <p class="admin-field-error" id="ccaImageUrlError"><%= fieldError("image_url") %></p>
              <% } else { %>
                <p class="form-hint">Optional. Use a complete HTTPS image address.</p>
              <% } %>
            </div>
          </div>

          <div class="admin-form-actions">
            <button type="submit" class="btn btn-primary">
              <%= isEditMode ? "Save CCA changes" : "Create CCA" %>
            </button>
            <a href="/admin/ccas" class="btn btn-outline">Cancel</a>
          </div>
        </form>
      </section>

      <% if (isEditMode) { %>
        <section class="admin-panel" aria-labelledby="ccaAvailabilityTitle">
          <div class="admin-panel-header">
            <div>
              <p class="admin-eyebrow">Quick action</p>
              <h2 class="admin-panel-title" id="ccaAvailabilityTitle">CCA availability</h2>
            </div>
          </div>
          <div class="admin-action-row">
            <div>
              <p class="admin-action-row-title">
                This CCA is currently
                <strong><%= currentStatus === "inactive" ? "inactive" : "active" %></strong>.
              </p>
              <p class="admin-action-row-copy">
                Inactive CCAs remain in administration records but are hidden from the public directory.
              </p>
            </div>
            <form
              action="/admin/ccas/<%= encodeURIComponent(String(ccaId)) %>/toggle-status"
              method="POST"
              class="admin-inline-form"
            >
              <input type="hidden" name="_csrf" value="<%= safeCsrfToken %>" />
              <input type="hidden" name="confirmStatusChange" value="yes" />
              <button type="submit" class="btn btn-outline">
                <%= currentStatus === "inactive" ? "Activate CCA" : "Deactivate CCA" %>
              </button>
            </form>
          </div>
        </section>

        <section class="admin-danger-panel" aria-labelledby="deleteCcaTitle">
          <div class="admin-danger-copy">
            <p class="admin-eyebrow admin-eyebrow--danger">Permanent action</p>
            <h2 id="deleteCcaTitle">Delete CCA</h2>
            <p>
              This permanently removes the CCA and its membership records.
              Deactivation is safer when the CCA may return later.
            </p>
          </div>

          <form
            action="/admin/ccas/<%= encodeURIComponent(String(ccaId)) %>/delete"
            method="POST"
            class="admin-reset-form"
          >
            <input type="hidden" name="_csrf" value="<%= safeCsrfToken %>" />

            <label class="admin-confirm-control" for="confirmDeleteCca">
              <input
                id="confirmDeleteCca"
                type="checkbox"
                name="confirmDelete"
                value="yes"
                required
              />
              <span>
                I confirm that I am permanently deleting
                <strong><%= fieldValue("cca_name", "ccaName") || "this CCA" %></strong>.
              </span>
            </label>

            <button type="submit" class="admin-danger-button">Delete CCA permanently</button>
          </form>
        </section>
      <% } %>
    </main>
  </div>

  <script src="/js/nav.js"></script>
</body>
</html>
