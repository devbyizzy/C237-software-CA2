<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect Admin - Activity Logs</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-page">
  <a class="admin-skip-link" href="#adminMain">Skip to admin activity logs</a>

  <%- include("partials/header", { user: user }) %>

  <%
    const activityAvailable =
      typeof available === "undefined" ? true : available === true;
    const adminLogs =
      typeof logs !== "undefined" && Array.isArray(logs) ? logs : [];
    const activeFilters =
      typeof filters !== "undefined" && filters && typeof filters === "object"
        ? filters
        : {};
    const adminOptions =
      typeof admins !== "undefined" && Array.isArray(admins) ? admins : [];
    const actionOptions =
      typeof actions !== "undefined" && Array.isArray(actions) ? actions : [];
    const targetTypeOptions =
      typeof targetTypes !== "undefined" && Array.isArray(targetTypes)
        ? targetTypes
        : [];
    const safeCsrfToken =
      typeof csrfToken === "string" ? csrfToken : "";
    const selectedAdmin = String(
      activeFilters.adminUserId !== undefined
        ? activeFilters.adminUserId
        : activeFilters.admin !== undefined
        ? activeFilters.admin
        : activeFilters.adminId !== undefined
          ? activeFilters.adminId
          : activeFilters.admin_user_id || ""
    );
    const selectedAction = String(activeFilters.action || "");
    const selectedTargetType = String(
      activeFilters.targetType !== undefined
        ? activeFilters.targetType
        : activeFilters.target_type || ""
    );

    function formatAdminDate(value) {
      if (!value) {
        return "Not available";
      }

      const date = new Date(value);
      if (Number.isNaN(date.getTime())) {
        return "Not available";
      }

      return new Intl.DateTimeFormat("en-SG", {
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      }).format(date);
    }

    function adminDateTime(value) {
      if (!value) {
        return "";
      }

      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? "" : date.toISOString();
    }

    function friendlyCode(value) {
      if (!value) {
        return "Not available";
      }

      return String(value)
        .replace(/[_-]+/g, " ")
        .replace(/\b\w/g, function (character) {
          return character.toUpperCase();
        });
    }

    function optionValue(option, keys) {
      if (typeof option === "string" || typeof option === "number") {
        return String(option);
      }

      if (!option || typeof option !== "object") {
        return "";
      }

      for (let index = 0; index < keys.length; index += 1) {
        const value = option[keys[index]];
        if (value !== undefined && value !== null) {
          return String(value);
        }
      }

      return "";
    }
  %>

  <div class="layout admin-layout">
    <%- include("partials/sidebar", {
      activePage: "activity",
      csrfToken: safeCsrfToken
    }) %>

    <main class="admin-main" id="adminMain">
      <div class="admin-page-header">
        <div>
          <p class="admin-eyebrow">Audit trail</p>
          <h1 class="admin-page-title">Admin Activity Logs</h1>
          <p class="admin-page-subtitle">
            Review security-sensitive changes made through RPConnect administration.
          </p>
        </div>

        <% if (activityAvailable) { %>
          <div class="admin-count-chip">
            <strong><%= adminLogs.length %></strong>
            <span><%= adminLogs.length === 1 ? "entry" : "entries" %></span>
          </div>
        <% } %>
      </div>

      <% if (!activityAvailable) { %>
        <section class="admin-panel" aria-labelledby="activityUnavailableTitle">
          <div class="admin-empty-state admin-empty-state--large">
            <span class="admin-empty-icon" aria-hidden="true">&#9776;</span>
            <h2 id="activityUnavailableTitle">Activity logging is unavailable</h2>
            <p>
              Install the provided admin activity-log migration before using
              this audit page or performing logged admin actions.
            </p>
            <a href="/admin" class="btn btn-outline">Back to dashboard</a>
          </div>
        </section>
      <% } else { %>
        <section class="admin-panel admin-filter-panel" aria-labelledby="activityFiltersTitle">
          <div class="admin-panel-header admin-panel-header--compact">
            <div>
              <p class="admin-eyebrow">Narrow the audit trail</p>
              <h2 class="admin-panel-title" id="activityFiltersTitle">Filter activity</h2>
            </div>
          </div>

          <form action="/admin/activity" method="GET" class="admin-filter-form">
            <div class="form-group admin-form-group">
              <label class="form-label" for="activityAdminFilter">Administrator</label>
              <select
                class="form-input admin-select"
                id="activityAdminFilter"
                name="admin"
              >
                <option value="">All administrators</option>
                <% adminOptions.forEach(function (admin) { %>
                  <%
                    const adminId = optionValue(admin, [
                      "user_id",
                      "admin_user_id",
                      "userId",
                      "id"
                    ]);
                    const adminUsername =
                      admin && typeof admin === "object"
                        ? admin.username || admin.name || `Admin #${adminId}`
                        : `Admin #${adminId}`;
                    const adminEmail =
                      admin && typeof admin === "object" ? admin.email : "";
                  %>
                  <option value="<%= adminId %>" <%= selectedAdmin === adminId ? "selected" : "" %>>
                    <%= adminUsername %><%= adminEmail ? ` — ${adminEmail}` : "" %>
                  </option>
                <% }); %>
              </select>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="activityActionFilter">Action</label>
              <select
                class="form-input admin-select"
                id="activityActionFilter"
                name="action"
              >
                <option value="">All actions</option>
                <% actionOptions.forEach(function (option) { %>
                  <%
                    const actionValue = optionValue(option, ["action", "value"]);
                  %>
                  <option value="<%= actionValue %>" <%= selectedAction === actionValue ? "selected" : "" %>>
                    <%= friendlyCode(actionValue) %>
                  </option>
                <% }); %>
              </select>
            </div>

            <div class="form-group admin-form-group">
              <label class="form-label" for="activityTargetFilter">Target type</label>
              <select
                class="form-input admin-select"
                id="activityTargetFilter"
                name="targetType"
              >
                <option value="">All target types</option>
                <% targetTypeOptions.forEach(function (option) { %>
                  <%
                    const targetValue = optionValue(option, [
                      "target_type",
                      "targetType",
                      "value"
                    ]);
                  %>
                  <option value="<%= targetValue %>" <%= selectedTargetType === targetValue ? "selected" : "" %>>
                    <%= friendlyCode(targetValue) %>
                  </option>
                <% }); %>
              </select>
            </div>

            <div class="admin-filter-actions">
              <button type="submit" class="btn btn-primary">Apply filters</button>
              <a href="/admin/activity" class="btn btn-outline">Clear</a>
            </div>
          </form>
        </section>

        <section class="admin-panel" aria-labelledby="activityTableTitle">
          <div class="admin-panel-header">
            <div>
              <p class="admin-eyebrow">Newest first</p>
              <h2 class="admin-panel-title" id="activityTableTitle">Recorded admin actions</h2>
            </div>
            <p class="admin-results-summary">
              Showing <strong><%= adminLogs.length %></strong>
              <%= adminLogs.length === 1 ? "entry" : "entries" %>
            </p>
          </div>

          <% if (adminLogs.length > 0) { %>
            <div
              class="admin-table-wrap"
              role="region"
              aria-labelledby="activityTableTitle"
              tabindex="0"
            >
              <table class="admin-table admin-activity-table">
                <caption class="admin-visually-hidden">
                  Admin activity matching the current filters, newest first
                </caption>
                <thead>
                  <tr>
                    <th scope="col">Timestamp</th>
                    <th scope="col">Administrator</th>
                    <th scope="col">Action</th>
                    <th scope="col">Target type</th>
                    <th scope="col">Target ID</th>
                  </tr>
                </thead>
                <tbody>
                  <% adminLogs.forEach(function (log) { %>
                    <tr>
                      <td>
                        <time datetime="<%= adminDateTime(log.created_at || log.createdAt) %>">
                          <%= formatAdminDate(log.created_at || log.createdAt) %>
                        </time>
                      </td>
                      <td>
                        <% if (log.admin_user_id === null || log.adminUserId === null) { %>
                          <span class="admin-table-muted">Deleted administrator</span>
                        <% } else { %>
                          <span class="admin-user-primary">
                            <%= log.admin_username || log.username || log.admin_name || "Administrator" %>
                          </span>
                          <% if (log.admin_email || log.email) { %>
                            <span class="admin-secondary-line admin-break-value">
                              <%= log.admin_email || log.email %>
                            </span>
                          <% } %>
                        <% } %>
                      </td>
                      <td>
                        <span class="admin-action-code"><%= friendlyCode(log.action) %></span>
                      </td>
                      <td>
                        <span class="admin-role-badge">
                          <%= friendlyCode(log.target_type || log.targetType) %>
                        </span>
                      </td>
                      <td>
                        <% if (
                          log.target_id !== undefined &&
                          log.target_id !== null
                        ) { %>
                          <span class="admin-id-chip">#<%= log.target_id %></span>
                        <% } else if (
                          log.targetId !== undefined &&
                          log.targetId !== null
                        ) { %>
                          <span class="admin-id-chip">#<%= log.targetId %></span>
                        <% } else { %>
                          <span class="admin-table-muted">Not available</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="admin-empty-state">
              <span class="admin-empty-icon" aria-hidden="true">&#9776;</span>
              <h3>No matching activity</h3>
              <p>No admin actions match the current filters.</p>
              <a href="/admin/activity" class="btn btn-outline">Clear filters</a>
            </div>
          <% } %>
        </section>
      <% } %>
    </main>
  </div>

  <script src="/js/nav.js"></script>
</body>
</html>
