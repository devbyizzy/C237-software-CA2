<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect Admin - Dashboard</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-page">
  <a class="admin-skip-link" href="#adminMain">Skip to dashboard content</a>

  <%- include("partials/header", { user: user }) %>

  <%
    const dashboardStats = stats || {};
    const statDefinitions = [
      {
        key: "users",
        label: "Total users",
        description: "Registered RPConnect accounts",
        icon: "U"
      },
      {
        key: "ccas",
        label: "Total CCAs",
        description: "Co-curricular activities",
        icon: "C"
      },
      {
        key: "groups",
        label: "RP Circles",
        description: "Student-created groups",
        icon: "G"
      },
      {
        key: "questions",
        label: "Total questions",
        description: "Questions shared by users",
        icon: "Q"
      }
    ];
    const dashboardCards = statDefinitions.map(function (definition) {
      const source = dashboardStats[definition.key] || {};
      return {
        label: definition.label,
        description: definition.description,
        icon: definition.icon,
        available: source.available === true,
        count: source.count
      };
    });
    const dashboardRecentUsers = Array.isArray(recentUsers) ? recentUsers : [];

    function formatAdminDate(value) {
      if (!value) {
        return "Not available";
      }

      const date = new Date(value);
      if (Number.isNaN(date.getTime())) {
        return "Not available";
      }

      return new Intl.DateTimeFormat("en-SG", {
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit"
      }).format(date);
    }

    function adminDateTime(value) {
      if (!value) {
        return "";
      }

      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? "" : date.toISOString();
    }
  %>

  <div class="layout admin-layout">
    <%- include("partials/sidebar", {
      activePage: "dashboard",
      csrfToken: typeof csrfToken === "string" ? csrfToken : ""
    }) %>

    <main class="admin-main" id="adminMain">
      <div class="admin-page-header">
        <div>
          <p class="admin-eyebrow">Overview</p>
          <h1 class="admin-page-title">Admin Dashboard</h1>
          <p class="admin-page-subtitle">
            A live overview of RPConnect accounts and community activity.
          </p>
        </div>

        <div class="admin-live-indicator">
          <span class="admin-live-dot" aria-hidden="true"></span>
          Database statistics
        </div>
      </div>

      <section class="admin-stats-grid" aria-label="RPConnect statistics">
        <% dashboardCards.forEach(function (stat) { %>
          <article class="admin-stat-card<%= stat.available ? "" : " admin-stat-card--unavailable" %>">
            <div class="admin-stat-card-top">
              <span class="admin-stat-icon" aria-hidden="true"><%= stat.icon %></span>
              <span class="admin-stat-status">
                <%= stat.available ? "Live" : "Unavailable" %>
              </span>
            </div>

            <p class="admin-stat-value">
              <%= stat.available ? stat.count : "—" %>
            </p>
            <h2 class="admin-stat-label"><%= stat.label %></h2>
            <p class="admin-stat-description"><%= stat.description %></p>
          </article>
        <% }); %>
      </section>

      <section class="admin-panel" aria-labelledby="recentUsersTitle">
        <div class="admin-panel-header">
          <div>
            <p class="admin-eyebrow">Latest registrations</p>
            <h2 class="admin-panel-title" id="recentUsersTitle">Recent users</h2>
          </div>

          <a href="/admin/users" class="btn btn-outline admin-compact-button">
            View all users
          </a>
        </div>

        <% if (dashboardRecentUsers.length > 0) { %>
          <div class="admin-table-wrap">
            <table class="admin-table">
              <caption class="admin-visually-hidden">
                Five most recently registered RPConnect users
              </caption>
              <thead>
                <tr>
                  <th scope="col">Username</th>
                  <th scope="col">Email</th>
                  <th scope="col">Role</th>
                  <th scope="col">Account created</th>
                </tr>
              </thead>
              <tbody>
                <% dashboardRecentUsers.forEach(function (recentUser) { %>
                  <%
                    const recentCreatedAt =
                      recentUser.created_at !== undefined
                        ? recentUser.created_at
                        : recentUser.createdAt;
                  %>
                  <tr>
                    <td>
                      <span class="admin-user-primary">
                        <%= recentUser.username || "Not available" %>
                      </span>
                    </td>
                    <td class="admin-table-muted">
                      <%= recentUser.email || "Not available" %>
                    </td>
                    <td>
                      <span class="admin-role-badge<%= recentUser.role === "admin" ? " admin-role-badge--admin" : "" %>">
                        <%= recentUser.role || "Not assigned" %>
                      </span>
                    </td>
                    <td>
                      <time datetime="<%= adminDateTime(recentCreatedAt) %>">
                        <%= formatAdminDate(recentCreatedAt) %>
                      </time>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="admin-empty-state">
            <span class="admin-empty-icon" aria-hidden="true">&#128100;</span>
            <h3>No recent registrations</h3>
            <p>Newly registered accounts will appear here.</p>
          </div>
        <% } %>
      </section>
    </main>
  </div>

  <script src="/js/nav.js"></script>
</body>
</html>
