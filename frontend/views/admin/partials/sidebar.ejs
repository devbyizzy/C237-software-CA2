<aside class="sidebar admin-sidebar" id="sidebar" aria-label="Admin navigation">
  <div class="admin-sidebar-heading">
    <span class="admin-sidebar-kicker">Control centre</span>
    <strong>Admin tools</strong>
  </div>

  <nav class="sidebar-nav admin-sidebar-nav">
    <a
      href="/admin"
      class="sidebar-link<%= activePage === "dashboard" ? " active" : "" %>"
      <% if (activePage === "dashboard") { %>aria-current="page"<% } %>
    >
      <span class="sidebar-icon" aria-hidden="true">&#9638;</span>
      Dashboard
    </a>

    <a
      href="/admin/users"
      class="sidebar-link<%= activePage === "users" ? " active" : "" %>"
      <% if (activePage === "users") { %>aria-current="page"<% } %>
    >
      <span class="sidebar-icon" aria-hidden="true">&#128101;</span>
      Users
    </a>

    <div class="admin-sidebar-separator" aria-hidden="true"></div>
    <span class="admin-sidebar-label">Community management</span>

    <a
      href="/admin/groups"
      class="sidebar-link<%= activePage === "groups" ? " active" : "" %>"
      <% if (activePage === "groups") { %>aria-current="page"<% } %>
    >
      <span class="sidebar-icon" aria-hidden="true">&#9673;</span>
      RP Circles
    </a>

    <a
      href="/admin/ccas"
      class="sidebar-link<%= activePage === "ccas" ? " active" : "" %>"
      <% if (activePage === "ccas") { %>aria-current="page"<% } %>
    >
      <span class="sidebar-icon" aria-hidden="true">&#9733;</span>
      CCAs
    </a>

    <a
      href="/admin/questions"
      class="sidebar-link<%= activePage === "questions" ? " active" : "" %>"
      <% if (activePage === "questions") { %>aria-current="page"<% } %>
    >
      <span class="sidebar-icon" aria-hidden="true">?</span>
      Questions
    </a>

    <a
      href="/admin/activity"
      class="sidebar-link<%= activePage === "activity" ? " active" : "" %>"
      <% if (activePage === "activity") { %>aria-current="page"<% } %>
    >
      <span class="sidebar-icon" aria-hidden="true">&#9776;</span>
      Activity Logs
    </a>

    <form action="/logout" method="POST" class="admin-sidebar-logout">
      <input
        type="hidden"
        name="_csrf"
        value="<%= typeof csrfToken === "string" ? csrfToken : "" %>"
      />
      <button type="submit" class="sidebar-link admin-sidebar-logout-button">
        <span class="sidebar-icon" aria-hidden="true">&#8617;</span>
        Logout
      </button>
    </form>
  </nav>
</aside>
