<header class="navbar admin-navbar">
  <div class="navbar-left">
    <button
      class="hamburger"
      id="hamburgerBtn"
      type="button"
      aria-label="Toggle admin navigation"
      aria-controls="sidebar"
      aria-expanded="false"
    >
      &#9776;
    </button>

    <a href="/admin" class="logo admin-logo">
      <span aria-hidden="true">&#127891;</span>
      RPConnect
    </a>

    <span class="admin-header-divider" aria-hidden="true"></span>
    <span class="admin-header-section">Administration</span>
  </div>

  <div class="navbar-right admin-header-account">
    <div class="admin-header-user-copy">
      <span class="admin-header-user-name">
        <%= user && (user.name || user.username) ? (user.name || user.username) : "Administrator" %>
      </span>
      <span class="admin-header-user-role">Admin account</span>
    </div>

    <div class="avatar avatar-sm admin-header-avatar" aria-hidden="true">
      <%= user && (user.name || user.username)
        ? String(user.name || user.username).charAt(0).toUpperCase()
        : "A"
      %>
    </div>
  </div>
</header>
