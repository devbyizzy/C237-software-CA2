<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>RPConnect - Dashboard</title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  />
</head>

<body>
  <header class="navbar">
    <div class="navbar-left">
      <button
        class="hamburger"
        id="hamburgerBtn"
        type="button"
        aria-label="Toggle menu"
      >
        ☰
      </button>

      <a href="/" class="logo">
        🎓 RPConnect
      </a>
    </div>

    <form
      class="navbar-search"
      action="#"
      method="GET"
      onsubmit="return false;"
    >
      <span class="search-icon">
        🔍
      </span>

      <input
        type="text"
        name="q"
        placeholder="Search students, questions, groups..."
      />
    </form>

    <div class="navbar-right">
      <button
        class="btn btn-primary create-btn"
        type="button"
      >
        + Create
      </button>

      <button
        class="icon-btn notif-btn"
        type="button"
        aria-label="Notifications"
        title="Notifications"
      >
        🔔

        <span
          class="notif-dot"
          id="notifDot"
          hidden
        ></span>
      </button>

      <div class="navbar-profile dropdown">
        <button
          class="navbar-profile-trigger"
          id="profileMenuBtn"
          type="button"
          aria-label="Open profile menu"
        >
          <div
            class="avatar avatar-sm"
            id="navAvatar"
          >
            <%= user && user.name
              ? user.name.charAt(0).toUpperCase()
              : "U"
            %>
          </div>

          <span
            class="navbar-username"
            id="navUsername"
          >
            <%= user && user.username
              ? user.username
              : user && user.name
                ? user.name
                : "User"
            %>
          </span>

          <span class="caret">
            ▾
          </span>
        </button>

        <div
          class="dropdown-menu"
          id="profileMenu"
        >
          <a
            href="/profile"
            class="dropdown-item"
          >
            🙍 My Profile
          </a>

          <a
            href="/profile"
            class="dropdown-item"
          >
            ⚙️ Settings
          </a>

          <form
            action="/logout"
            method="POST"
            class="logout-form"
          >
            <button
              type="submit"
              class="dropdown-item logout-item"
            >
              🚪 Logout
            </button>
          </form>
        </div>
      </div>
    </div>
  </header>

  <div class="layout">
    <aside
      class="sidebar"
      id="sidebar"
    >
      <nav class="sidebar-nav">
        <a
          href="/"
          class="sidebar-link active"
        >
          <span class="sidebar-icon">
            🏠
          </span>

          Home
        </a>

        <a
          href="#"
          class="sidebar-link"
        >
          <span class="sidebar-icon">
            ❓
          </span>

          Questions
        </a>

        <a
          href="#"
          class="sidebar-link"
        >
          <span class="sidebar-icon">
            👥
          </span>

          Groups
        </a>
        <a href="/ccas" class="sidebar-link">
          <span class="sidebar-icon">🎭</span> CCAs
        </a>

        <a
          href="#"
          class="sidebar-link"
        >
          <span class="sidebar-icon">
            🗓️
          </span>

          Timetables
        </a>

        <a
          href="/students"
          class="sidebar-link"
        >
          <span class="sidebar-icon">
            🔎
          </span>

          Student Finder
        </a>

        <a
          href="#"
          class="sidebar-link"
        >
          <span class="sidebar-icon">
            📌
          </span>

          My Groups
        </a>

        <a
          href="/profile"
          class="sidebar-link"
        >
          <span class="sidebar-icon">
            🙍
          </span>

          My Profile
        </a>
      </nav>
    </aside>

    <main class="feed">
      <h1
        class="feed-title"
        id="feedTitle"
      >
        Welcome back,
        <%= user && user.name
          ? user.name
          : user && user.username
            ? user.username
            : "User"
        %>
        👋
      </h1>

      <section class="feed-section">
        <div class="feed-section-header">
          <h2>
            Latest Questions
          </h2>

          <a
            href="#"
            class="see-all"
          >
            See all
          </a>
        </div>

        <div id="latestQuestions"></div>
      </section>

      <section class="feed-section">
        <div class="feed-section-header">
          <h2>
            New Groups
          </h2>

          <a
            href="#"
            class="see-all"
          >
            See all
          </a>
        </div>

        <div id="newGroups"></div>
      </section>

      <section class="feed-section">
        <div class="feed-section-header">
          <h2>
            CCA Announcements
          </h2>

          <a
            href="#"
            class="see-all"
          >
            See all
          </a>
        </div>

        <div id="ccaAnnouncements"></div>
      </section>

      <section class="feed-section">
        <div class="feed-section-header">
          <h2>
            Shared Timetables
          </h2>

          <a
            href="#"
            class="see-all"
          >
            See all
          </a>
        </div>

        <div id="sharedTimetables"></div>
      </section>
    </main>

    <aside class="right-panel">
      <section class="panel-section">
        <h2>
          🔥 Trending Questions
        </h2>

        <div id="trendingQuestions"></div>
      </section>

      <section class="panel-section">
        <h2>
          👥 Popular Groups
        </h2>

        <div id="popularGroups"></div>
      </section>

      <section class="panel-section">
        <h2>
          🎭 Recommended CCAs
        </h2>

        <div id="recommendedCcas"></div>
      </section>

      <section class="panel-section">
        <h2>
          ✨ Suggested Students
        </h2>

        <div id="suggestedStudents"></div>
      </section>
    </aside>
  </div>

  <script src="/js/config.js"></script>
  <script src="/js/nav.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>