<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect - Groups</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="navbar">
    <div class="navbar-left">
      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">☰</button>
      <a href="/" class="logo">🎓 RPConnect</a>
    </div>

    <form class="navbar-search" action="#" method="GET" onsubmit="return false;">
      <span class="search-icon">🔍</span>
      <input type="text" name="q" placeholder="Search students, questions, groups..." />
    </form>

    <div class="navbar-right">
      <button class="btn btn-primary create-btn">+ Create</button>

      <button class="icon-btn notif-btn" aria-label="Notifications" title="Notifications">
        🔔
        <span class="notif-dot" id="notifDot" hidden></span>
      </button>

      <div class="navbar-profile dropdown">
        <button class="navbar-profile-trigger" id="profileMenuBtn">
          <div class="avatar avatar-sm" id="navAvatar"></div>
          <span class="navbar-username" id="navUsername"></span>
          <span class="caret">▾</span>
        </button>
        <div class="dropdown-menu" id="profileMenu">
          <a href="/profile" class="dropdown-item">🙍 My Profile</a>
          <a href="/profile" class="dropdown-item">⚙️ Settings</a>
          <a href="#" class="dropdown-item logout-item">🚪 Logout</a>
        </div>
      </div>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">
        <a href="/" class="sidebar-link">
          <span class="sidebar-icon">🏠</span> Home
        </a>
        <a href="/groups" class="sidebar-link active">
          <span class="sidebar-icon">👥</span> Groups
        </a>
        <a href="/interest-groups" class="sidebar-link">
          <span class="sidebar-icon">✨</span> Interest Groups
        </a>
        <a href="/forum" class="sidebar-link">
          <span class="sidebar-icon">💬</span> Forum
        </a>
        <a href="/ccas" class="sidebar-link">
          <span class="sidebar-icon">🎭</span> CCAs
        </a>
        <a href="/students" class="sidebar-link">
          <span class="sidebar-icon">🔎</span> Student Finder
        </a>
        <a href="/groups?mine=1" class="sidebar-link">
          <span class="sidebar-icon">📌</span> My Groups
        </a>
        <a href="/profile" class="sidebar-link">
          <span class="sidebar-icon">🙍</span> My Profile
        </a>
      </nav>
    </aside>

    <main class="feed">
      <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
        <div>
          <h1 class="feed-title" id="groupsTitle">RP Circles</h1>
          <p style="font-size:14px; color:var(--text-muted);">Find classmates, join study groups and make new friends.</p>
        </div>
        <a href="/groups/create" class="btn btn-primary" style="white-space:nowrap;">+ Create Group</a>
      </div>

      <section class="feed-section">
        <div class="card">
          <form id="groupFilterForm" class="search-filters">
            <div class="form-group" style="margin-bottom:0; grid-column:1 / -1;">
              <label class="form-label" for="searchInput">Search</label>
              <input class="form-input" type="text" id="searchInput" name="search" placeholder="Search group names and descriptions..." />
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="typeSelect">Group Type</label>
              <select class="form-input" id="typeSelect" name="type">
                <option value="">All types</option>
                <option value="class">Class Group</option>
                <option value="study">Study Group</option>
                <option value="cca">CCA Group</option>
                <option value="interest">Interest Group</option>
                <option value="friend">Friend Group</option>
              </select>
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="diplomaInput">Diploma</label>
              <input class="form-input" type="text" id="diplomaInput" name="diploma" placeholder="e.g. Information Technology" />
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="classInput">Class</label>
              <input class="form-input" type="text" id="classInput" name="class_code" placeholder="e.g. E36A" />
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="sortSelect">Sort By</label>
              <select class="form-input" id="sortSelect" name="sort">
                <option value="newest">Newest first</option>
                <option value="oldest">Oldest first</option>
                <option value="popular">Most members</option>
                <option value="name">Name (A–Z)</option>
              </select>
            </div>
            <div class="form-actions" style="margin-top:0;">
              <button type="submit" class="btn btn-primary">Search</button>
              <button type="button" id="clearFiltersBtn" class="btn btn-outline">Clear</button>
            </div>
          </form>
        </div>
      </section>

      <section class="feed-section">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:12px;">
          <p class="results-count" id="resultsCount"></p>
          <button type="button" id="mineToggleBtn" class="btn btn-outline" style="font-size:13px;">📌 My groups only</button>
        </div>
        <div class="search-results-grid" id="groupResults"></div>
      </section>
    </main>

    <aside class="right-panel">
      <section class="panel-section">
        <h2>💡 Recommended for you</h2>
        <div id="recommendedGroupsContent"><p class="mini-meta">Loading...</p></div>
      </section>

      <section class="panel-section">
        <h2>🔥 Popular Groups</h2>
        <div id="popularGroupsContent"><p class="mini-meta">Loading...</p></div>
      </section>

      <section class="panel-section">
        <h2>🆕 Recently Created</h2>
        <div id="recentGroupsContent"><p class="mini-meta">Loading...</p></div>
      </section>

      <section class="panel-section">
        <h2>📌 Groups You Joined</h2>
        <div id="joinedGroupsContent"><p class="mini-meta">Loading...</p></div>
      </section>
    </aside>
  </div>

  <script>
    window.CURRENT_USER = <%- JSON.stringify(user || null).replace(/</g, '\\u003c') %>;
  </script>
  <script src="/js/config.js"></script>
  <script src="/js/nav.js"></script>
  <script src="/js/groups.js"></script>
</body>
</html>
