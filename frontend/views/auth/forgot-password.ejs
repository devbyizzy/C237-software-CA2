<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>Forgot Password | RPConnect</title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  />
</head>

<body class="auth-page">
  <div class="auth-background">
    <div class="auth-glow auth-glow-primary"></div>
    <div class="auth-glow auth-glow-accent"></div>
    <div class="auth-grid"></div>
  </div>

  <main class="auth-layout">
    <section class="auth-brand-panel">
      <a href="/login" class="auth-logo">
        <span class="auth-logo-icon">RP</span>
        <span class="auth-logo-name">
          RPConnect
        </span>
      </a>

      <div class="auth-brand-content">
        <span class="auth-eyebrow">
          Account recovery
        </span>

        <h1 class="auth-brand-title">
          Reset your
          <span>password securely.</span>
        </h1>

        <p class="auth-brand-description">
          Enter your registered RP email.
          A temporary password-reset link will
          be generated for your account.
        </p>
      </div>

      <p class="auth-brand-footer">
        Republic Polytechnic Student Community
      </p>
    </section>

    <section class="auth-form-panel">
      <div class="auth-form-container">
        <div class="auth-mobile-logo">
          <a href="/login" class="auth-logo">
            <span class="auth-logo-icon">RP</span>
            <span class="auth-logo-name">
              RPConnect
            </span>
          </a>
        </div>

        <header class="auth-form-heading">
          <span class="auth-form-label">
            Password recovery
          </span>

          <h2>Forgot your password?</h2>

          <p>
            Enter the RP email connected to your
            account.
          </p>
        </header>

        <% if (error) { %>
          <div class="auth-alert auth-alert-error">
            <span class="auth-alert-icon">!</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <% if (success) { %>
          <div class="auth-alert auth-alert-success">
            <span class="auth-alert-icon">✓</span>
            <span><%= success %></span>
          </div>
        <% } %>

        <form
          method="POST"
          action="/forgot-password"
          class="auth-form"
        >
          <div class="auth-field">
            <label for="email">
              RP email
            </label>

            <div class="auth-input-wrapper">
              <span class="auth-input-icon">@</span>

              <input
                type="email"
                id="email"
                name="email"
                value="<%= formData.email || '' %>"
                placeholder="12345678@myrp.edu.sg"
                autocomplete="email"
                required
              />
            </div>
          </div>

          <button
            type="submit"
            class="auth-submit-button"
          >
            Generate reset link
            <span class="auth-button-arrow">→</span>
          </button>
        </form>

        <% if (resetLink) { %>
          <div
            class="auth-alert auth-alert-success"
            style="margin-top: 20px;"
          >
            <span class="auth-alert-icon">✓</span>

            <span>
              Development reset link:
              <br />

              <a href="<%= resetLink %>">
                Reset my password
              </a>
            </span>
          </div>
        <% } %>

        <div class="auth-divider">
          <span></span>
          <p>Remembered your password?</p>
          <span></span>
        </div>

        <a
          href="/login"
          class="auth-secondary-button"
        >
          Return to login
        </a>
      </div>
    </section>
  </main>
</body>
</html>