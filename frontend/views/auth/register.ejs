<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <meta
    name="description"
    content="Create your RPConnect student account."
  />

  <title>Register | RPConnect</title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  />

  <script
    src="/js/auth.js"
    defer
  ></script>
</head>

<body class="auth-page">
  <div class="auth-background">
    <div class="auth-glow auth-glow-primary"></div>
    <div class="auth-glow auth-glow-accent"></div>
    <div class="auth-grid"></div>
  </div>

  <main class="auth-layout">
    <section class="auth-brand-panel">
      <a
        href="/"
        class="auth-logo"
        aria-label="RPConnect home"
      >
        <span class="auth-logo-icon">RP</span>
        <span class="auth-logo-name">RPConnect</span>
      </a>

      <div class="auth-brand-content">
        <span class="auth-eyebrow">
          Join the RP community
        </span>

        <h1 class="auth-brand-title">
          Your community
          <span>starts here.</span>
        </h1>

        <p class="auth-brand-description">
          Create your account using your RP student email and
          begin connecting with communities across campus.
        </p>

        <div class="auth-feature-list">
          <div class="auth-feature-item">
            <div class="auth-feature-icon">01</div>

            <div>
              <h2>One student account</h2>
              <p>
                Register securely using your official RP email address.
              </p>
            </div>
          </div>

          <div class="auth-feature-item">
            <div class="auth-feature-icon">02</div>

            <div>
              <h2>Personalised discovery</h2>
              <p>
                Explore student groups and communities that match your interests.
              </p>
            </div>
          </div>

          <div class="auth-feature-item">
            <div class="auth-feature-icon">03</div>

            <div>
              <h2>Build connections</h2>
              <p>
                Meet students, share ideas and participate in campus life.
              </p>
            </div>
          </div>
        </div>
      </div>

      <p class="auth-brand-footer">
        Open exclusively to Republic Polytechnic students.
      </p>
    </section>

    <section class="auth-form-panel auth-register-panel">
      <div class="auth-form-container">
        <div class="auth-mobile-logo">
          <a
            href="/"
            class="auth-logo"
            aria-label="RPConnect home"
          >
            <span class="auth-logo-icon">RP</span>
            <span class="auth-logo-name">RPConnect</span>
          </a>
        </div>

        <div class="auth-form-heading">
          <span class="auth-form-label">
            Student registration
          </span>

          <h2>Create your account</h2>

          <p>
            Use your official RP email to join RPConnect.
          </p>
        </div>

        <% if (typeof error !== "undefined" && error) { %>
          <div
            class="auth-alert auth-alert-error"
            role="alert"
          >
            <span class="auth-alert-icon">!</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <% if (typeof success !== "undefined" && success) { %>
          <div
            class="auth-alert auth-alert-success"
            role="status"
          >
            <span class="auth-alert-icon">✓</span>
            <span><%= success %></span>
          </div>
        <% } %>

        <form
          class="auth-form"
          action="/register"
          method="POST"
          data-auth-form="register"
          novalidate
        >
          <div class="auth-field">
            <label for="name">
              Full name
            </label>

            <div class="auth-input-wrapper">
              <span
                class="auth-input-icon"
                aria-hidden="true"
              >
                A
              </span>

              <input
                type="text"
                id="name"
                name="name"
                value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>"
                placeholder="Enter your full name"
                autocomplete="name"
                minlength="2"
                maxlength="100"
                required
              />
            </div>

            <p
              class="auth-field-message"
              data-error-for="name"
            ></p>
          </div>

          <div class="auth-field">
            <label for="username">
              Username
            </label>

            <div class="auth-input-wrapper">
              <span
                class="auth-input-icon"
                aria-hidden="true"
              >
                @
              </span>

              <input
                type="text"
                id="username"
                name="username"
                value="<%= typeof formData !== 'undefined' && formData.username ? formData.username : '' %>"
                placeholder="Choose a username"
                autocomplete="username"
                minlength="3"
                maxlength="20"
                pattern="[A-Za-z0-9_]{3,20}"
                required
              />
            </div>

            <p class="auth-field-hint">
              Use 3 to 20 letters, numbers or underscores.
            </p>

            <p
              class="auth-field-message"
              data-error-for="username"
            ></p>
          </div>

          <div class="auth-field">
            <label for="email">
              RP email address
            </label>

            <div class="auth-input-wrapper">
              <span
                class="auth-input-icon"
                aria-hidden="true"
              >
                @
              </span>

              <input
                type="email"
                id="email"
                name="email"
                value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
                placeholder="23012345@myrp.edu.sg"
                autocomplete="email"
                inputmode="email"
                pattern="[0-9]{8}@myrp\.edu\.sg"
                required
              />
            </div>

            <p class="auth-field-hint">
              Your email must contain 8 digits followed by @myrp.edu.sg.
            </p>

            <p
              class="auth-field-message"
              data-error-for="email"
            ></p>
          </div>

          <div class="auth-field">
            <label for="password">
              Password
            </label>

            <div class="auth-input-wrapper">
              <span
                class="auth-input-icon auth-lock-icon"
                aria-hidden="true"
              >
                ●
              </span>

              <input
                type="password"
                id="password"
                name="password"
                placeholder="Create a secure password"
                autocomplete="new-password"
                minlength="8"
                required
              />

              <button
                type="button"
                class="auth-password-toggle"
                data-password-toggle="password"
                aria-label="Show password"
                aria-pressed="false"
              >
                <span class="auth-eye-show">Show</span>
                <span class="auth-eye-hide">Hide</span>
              </button>
            </div>

            <div class="auth-password-requirements">
              <p
                class="auth-requirement"
                data-password-rule="length"
              >
                <span>○</span>
                At least 8 characters
              </p>

              <p
                class="auth-requirement"
                data-password-rule="uppercase"
              >
                <span>○</span>
                At least one uppercase letter
              </p>

              <p
                class="auth-requirement"
                data-password-rule="lowercase"
              >
                <span>○</span>
                At least one lowercase letter
              </p>

              <p
                class="auth-requirement"
                data-password-rule="number"
              >
                <span>○</span>
                At least one number
              </p>
            </div>

            <p
              class="auth-field-message"
              data-error-for="password"
            ></p>
          </div>

          <div class="auth-field">
            <label for="confirmPassword">
              Confirm password
            </label>

            <div class="auth-input-wrapper">
              <span
                class="auth-input-icon auth-lock-icon"
                aria-hidden="true"
              >
                ●
              </span>

              <input
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                placeholder="Enter your password again"
                autocomplete="new-password"
                minlength="8"
                required
              />

              <button
                type="button"
                class="auth-password-toggle"
                data-password-toggle="confirmPassword"
                aria-label="Show confirmed password"
                aria-pressed="false"
              >
                <span class="auth-eye-show">Show</span>
                <span class="auth-eye-hide">Hide</span>
              </button>
            </div>

            <p
              class="auth-field-message"
              data-error-for="confirmPassword"
            ></p>
          </div>

          <label class="auth-checkbox auth-agreement-checkbox">
            <input
              type="checkbox"
              id="agreement"
              name="agreement"
              value="accepted"
              required
            />

            <span class="auth-checkbox-box"></span>

            <span>
              I agree to use RPConnect responsibly and follow
              the student community guidelines.
            </span>
          </label>

          <p
            class="auth-field-message"
            data-error-for="agreement"
          ></p>

          <button
            type="submit"
            class="auth-submit-button"
          >
            <span>Create account</span>
            <span
              class="auth-button-arrow"
              aria-hidden="true"
            >
              →
            </span>
          </button>
        </form>

        <div class="auth-divider">
          <span></span>
          <p>Already registered?</p>
          <span></span>
        </div>

        <a
          href="/login"
          class="auth-secondary-button"
        >
          Log in to your account
        </a>

        <p class="auth-terms">
          Your password will never be displayed or stored in
          the browser by this page.
        </p>
      </div>
    </section>
  </main>
</body>
</html>