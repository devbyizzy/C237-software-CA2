<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>Reset Password | RPConnect</title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  />
</head>

<body class="auth-page">
  <div class="auth-background">
    <div class="auth-glow auth-glow-primary"></div>
    <div class="auth-glow auth-glow-accent"></div>
    <div class="auth-grid"></div>
  </div>

  <main class="auth-layout">
    <section class="auth-brand-panel">
      <a href="/login" class="auth-logo">
        <span class="auth-logo-icon">RP</span>

        <span class="auth-logo-name">
          RPConnect
        </span>
      </a>

      <div class="auth-brand-content">
        <span class="auth-eyebrow">
          Secure password reset
        </span>

        <h1 class="auth-brand-title">
          Create a new
          <span>secure password.</span>
        </h1>

        <p class="auth-brand-description">
          Choose a password that you do not use
          for another account.
        </p>

        <div class="auth-feature-list">
          <div class="auth-feature-item">
            <div class="auth-feature-icon">
              8+
            </div>

            <div>
              <h2>At least 8 characters</h2>

              <p>
                Use a longer password to make your
                account harder to compromise.
              </p>
            </div>
          </div>

          <div class="auth-feature-item">
            <div class="auth-feature-icon">
              Aa
            </div>

            <div>
              <h2>Uppercase and lowercase</h2>

              <p>
                Include at least one uppercase and
                one lowercase letter.
              </p>
            </div>
          </div>

          <div class="auth-feature-item">
            <div class="auth-feature-icon">
              123
            </div>

            <div>
              <h2>Include a number</h2>

              <p>
                Your new password must contain at
                least one number.
              </p>
            </div>
          </div>
        </div>
      </div>

      <p class="auth-brand-footer">
        Republic Polytechnic Student Community
      </p>
    </section>

    <section class="auth-form-panel">
      <div class="auth-form-container">
        <div class="auth-mobile-logo">
          <a href="/login" class="auth-logo">
            <span class="auth-logo-icon">
              RP
            </span>

            <span class="auth-logo-name">
              RPConnect
            </span>
          </a>
        </div>

        <header class="auth-form-heading">
          <span class="auth-form-label">
            Password reset
          </span>

          <h2>Set your new password</h2>

          <p>
            Enter and confirm your new account
            password.
          </p>
        </header>

        <% if (error) { %>
          <div class="auth-alert auth-alert-error">
            <span class="auth-alert-icon">
              !
            </span>

            <span><%= error %></span>
          </div>
        <% } %>

        <% if (success) { %>
          <div class="auth-alert auth-alert-success">
            <span class="auth-alert-icon">
              ✓
            </span>

            <span><%= success %></span>
          </div>
        <% } %>

        <% if (tokenValid) { %>
          <form
            method="POST"
            action="/reset-password"
            class="auth-form"
          >
            <input
              type="hidden"
              name="token"
              value="<%= token %>"
            />

            <div class="auth-field">
              <label for="password">
                New password
              </label>

              <div class="auth-input-wrapper">
                <span class="auth-input-icon auth-lock-icon">
                  ●
                </span>

                <input
                  type="password"
                  id="password"
                  name="password"
                  placeholder="Enter your new password"
                  autocomplete="new-password"
                  required
                />
              </div>

              <p class="auth-field-hint">
                Minimum 8 characters with uppercase,
                lowercase and a number.
              </p>
            </div>

            <div class="auth-field">
              <label for="confirmPassword">
                Confirm new password
              </label>

              <div class="auth-input-wrapper">
                <span class="auth-input-icon auth-lock-icon">
                  ●
                </span>

                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  placeholder="Re-enter your new password"
                  autocomplete="new-password"
                  required
                />
              </div>
            </div>

            <button
              type="submit"
              class="auth-submit-button"
            >
              Reset password

              <span class="auth-button-arrow">
                →
              </span>
            </button>
          </form>
        <% } %>

        <div class="auth-divider">
          <span></span>

          <p>Return to your account</p>

          <span></span>
        </div>

        <a
          href="/login"
          class="auth-secondary-button"
        >
          Back to login
        </a>
      </div>
    </section>
  </main>
</body>
</html>