<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>Verify Login | RPConnect</title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  >
</head>

<body class="auth-page">

  <div class="auth-background">
    <div class="auth-glow auth-glow-primary"></div>
    <div class="auth-glow auth-glow-accent"></div>
    <div class="auth-grid"></div>
  </div>

  <main class="auth-layout">

    <!-- Left branding panel -->
    <section class="auth-brand-panel">

      <a href="/login" class="auth-logo">
        <div class="auth-logo-icon">RP</div>
        <span class="auth-logo-name">RPConnect</span>
      </a>

      <div class="auth-brand-content">

        <span class="auth-eyebrow">
          Secure authentication
        </span>

        <h1 class="auth-brand-title">
          One more step.
          <span>Verify your identity.</span>
        </h1>

        <p class="auth-brand-description">
          Enter the temporary verification code from your
          authenticator application to securely access your
          RPConnect account.
        </p>

        <div class="auth-feature-list">

          <article class="auth-feature-item">
            <div class="auth-feature-icon">01</div>

            <div>
              <h2>Open your authenticator</h2>

              <p>
                Open Google Authenticator, Microsoft Authenticator,
                Authy, or another compatible application.
              </p>
            </div>
          </article>

          <article class="auth-feature-item">
            <div class="auth-feature-icon">02</div>

            <div>
              <h2>Find RPConnect</h2>

              <p>
                Locate the RPConnect account that you added during
                your initial two-factor authentication setup.
              </p>
            </div>
          </article>

          <article class="auth-feature-item">
            <div class="auth-feature-icon">03</div>

            <div>
              <h2>Enter the current code</h2>

              <p>
                Enter the current six-digit code before it expires
                to complete your login securely.
              </p>
            </div>
          </article>

        </div>
      </div>

      <p class="auth-brand-footer">
        Republic Polytechnic student community platform
      </p>

    </section>

    <!-- Verification form -->
    <section class="auth-form-panel">

      <div class="auth-form-container">

        <a href="/login" class="auth-logo auth-mobile-logo">
          <div class="auth-logo-icon">RP</div>
          <span class="auth-logo-name">RPConnect</span>
        </a>

        <header class="auth-form-heading">
          <span class="auth-form-label">
            Two-factor authentication
          </span>

          <h2>Verify Your Login</h2>

          <p>
            Enter the six-digit code shown in your authenticator app.
          </p>
        </header>

        <% if (error) { %>
          <div class="auth-alert auth-alert-error">
            <span class="auth-alert-icon">!</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <form
          action="/verify-2fa"
          method="POST"
          class="auth-form"
        >

          <div class="auth-field">

            <label for="code">
              Authentication code
            </label>

            <input
              type="text"
              id="code"
              name="code"
              class="auth-code-input"
              inputmode="numeric"
              autocomplete="one-time-code"
              pattern="[0-9]{6}"
              minlength="6"
              maxlength="6"
              placeholder="000000"
              aria-describedby="codeHint"
              required
              autofocus
            >

            <p
              id="codeHint"
              class="auth-field-hint"
            >
              Codes refresh approximately every 30 seconds.
            </p>

          </div>

          <button
            type="submit"
            class="auth-submit-button full-width"
          >
            <span>Verify and Log In</span>
            <span class="auth-button-arrow">→</span>
          </button>

        </form>

        <div class="auth-divider">
          <span></span>
          <p>Need to start again?</p>
          <span></span>
        </div>

        <form
          action="/cancel-2fa"
          method="POST"
        >
          <button
            type="submit"
            class="auth-secondary-button auth-full-width"
          >
            Cancel and return to login
          </button>
        </form>

        <p class="auth-terms">
          Never share your authentication code with anyone.
          RPConnect staff will never ask for your code.
        </p>

      </div>

    </section>

  </main>

</body>
</html>