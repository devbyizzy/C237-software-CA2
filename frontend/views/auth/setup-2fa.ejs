<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>Set Up 2FA | RPConnect</title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  >
</head>

<body class="auth-page">

  <%
    const displayedError =
      typeof error !== "undefined"
        ? error
        : null;

    const displayedQrCode =
      typeof qrCode !== "undefined" && qrCode
        ? qrCode
        : typeof qrCodeDataUrl !== "undefined" && qrCodeDataUrl
          ? qrCodeDataUrl
          : typeof qrCodeImage !== "undefined" && qrCodeImage
            ? qrCodeImage
            : typeof twoFactorQrCode !== "undefined" && twoFactorQrCode
              ? twoFactorQrCode
              : null;
  %>

  <div class="auth-background">
    <div class="auth-glow auth-glow-primary"></div>
    <div class="auth-glow auth-glow-accent"></div>
    <div class="auth-grid"></div>
  </div>

  <main class="auth-layout">

    <!-- Left branding panel -->
    <section class="auth-brand-panel">

      <a href="/login" class="auth-logo">
        <div class="auth-logo-icon">RP</div>

        <span class="auth-logo-name">
          RPConnect
        </span>
      </a>

      <div class="auth-brand-content">

        <span class="auth-eyebrow">
          Account protection
        </span>

        <h1 class="auth-brand-title">
          Secure your account.

          <span>
            Set up two-factor authentication.
          </span>
        </h1>

        <p class="auth-brand-description">
          Connect RPConnect to an authenticator application.
          This adds another layer of protection beyond your password.
        </p>

        <div class="auth-feature-list">

          <article class="auth-feature-item">
            <div class="auth-feature-icon">
              01
            </div>

            <div>
              <h2>
                Install an authenticator
              </h2>

              <p>
                Use Google Authenticator, Microsoft Authenticator,
                Authy, or another TOTP-compatible application.
              </p>
            </div>
          </article>

          <article class="auth-feature-item">
            <div class="auth-feature-icon">
              02
            </div>

            <div>
              <h2>
                Scan the QR code
              </h2>

              <p>
                Open your authenticator app, add a new account,
                and scan the QR code displayed on this page.
              </p>
            </div>
          </article>

          <article class="auth-feature-item">
            <div class="auth-feature-icon">
              03
            </div>

            <div>
              <h2>
                Confirm your setup
              </h2>

              <p>
                Enter the current six-digit code generated by your
                authenticator app to activate two-factor authentication.
              </p>
            </div>
          </article>

        </div>
      </div>

      <p class="auth-brand-footer">
        Republic Polytechnic student community platform
      </p>

    </section>

    <!-- Right setup panel -->
    <section class="auth-form-panel auth-register-panel">

      <div class="auth-form-container">

        <a
          href="/login"
          class="auth-logo auth-mobile-logo"
        >
          <div class="auth-logo-icon">
            RP
          </div>

          <span class="auth-logo-name">
            RPConnect
          </span>
        </a>

        <header class="auth-form-heading">

          <span class="auth-form-label">
            Mandatory security setup
          </span>

          <h2>
            Set Up Two-Factor Authentication
          </h2>

          <p>
            Scan the QR code and enter the six-digit code generated
            by your authenticator application.
          </p>

        </header>

        <% if (displayedError) { %>

          <div class="auth-alert auth-alert-error">
            <span class="auth-alert-icon">
              !
            </span>

            <span>
              <%= displayedError %>
            </span>
          </div>

        <% } %>

        <% if (displayedQrCode) { %>

          <div class="auth-qr-container">

            <div class="auth-qr-card">
              <img
                src="<%= displayedQrCode %>"
                alt="RPConnect two-factor authentication QR code"
              >
            </div>

          </div>

          <div class="auth-setup-steps">

            <h3>
              How to connect your app
            </h3>

            <ol>
              <li>
                Open your authenticator application.
              </li>

              <li>
                Select the option to add a new account.
              </li>

              <li>
                Scan the QR code displayed above.
              </li>

              <li>
                Enter the generated six-digit code below.
              </li>
            </ol>

          </div>

          <form
            action="/setup-2fa"
            method="POST"
            class="auth-form"
          >

            <div class="auth-field">

              <label for="code">
                Authentication code
              </label>

              <input
                type="text"
                id="code"
                name="code"
                class="auth-code-input"
                inputmode="numeric"
                autocomplete="one-time-code"
                pattern="[0-9]{6}"
                minlength="6"
                maxlength="6"
                placeholder="000000"
                aria-describedby="setupCodeHint"
                required
                autofocus
              >

              <p
                id="setupCodeHint"
                class="auth-field-hint"
              >
                Enter the current code shown in your authenticator app.
              </p>

            </div>

            <button
              type="submit"
              class="auth-submit-button auth-full-width"
            >
              <span>
                Confirm and Continue
              </span>

              <span class="auth-button-arrow">
                →
              </span>
            </button>

          </form>

          <div class="auth-security-note">
            Two-factor authentication is mandatory for RPConnect accounts.
            You will need a new authentication code whenever you sign in.
          </div>

        <% } else { %>

          <div class="auth-alert auth-alert-error">

            <span class="auth-alert-icon">
              !
            </span>

            <span>
              The QR code could not be generated.
              Return to login and try again.
            </span>

          </div>

        <% } %>

        <div class="auth-divider">
          <span></span>

          <p>
            Need to restart?
          </p>

          <span></span>
        </div>

        <form
          action="/cancel-2fa"
          method="POST"
        >
          <button
            type="submit"
            class="auth-secondary-button auth-full-width"
          >
            Cancel and return to login
          </button>
        </form>

        <p class="auth-terms">
          Do not share your QR code, setup secret,
          or authentication codes with anyone.
        </p>

      </div>

    </section>

  </main>

</body>
</html>