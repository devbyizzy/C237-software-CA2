<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect - Add CCA</title>
  <link rel="stylesheet" href="/css/style.css" />
  <script src="https://cdn.jsdelivr.net/npm/@tabler/icons@latest/tabler-icons.min.js"></script>
</head>
<body>

  <header class="navbar">
    <div class="navbar-left">
      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">☰</button>
      <a href="/" class="logo">🎓 RPConnect</a>
    </div>

    <form class="navbar-search" action="#" method="GET" onsubmit="return false;">
      <span class="search-icon">🔍</span>
      <input type="text" name="q" placeholder="Search students, questions, groups..." />
    </form>

    <div class="navbar-right">
      <button class="btn btn-primary create-btn">+ Create</button>

      <button class="icon-btn notif-btn" aria-label="Notifications" title="Notifications">
        🔔
        <span class="notif-dot" id="notifDot" hidden></span>
      </button>

      <div class="navbar-profile dropdown">
        <button class="navbar-profile-trigger" id="profileMenuBtn">
          <div class="avatar avatar-sm" id="navAvatar"></div>
          <span class="navbar-username" id="navUsername"></span>
          <span class="caret">▾</span>
        </button>
        <div class="dropdown-menu" id="profileMenu">
          <a href="/profile" class="dropdown-item">🙍 My Profile</a>
          <a href="/profile" class="dropdown-item">⚙️ Settings</a>
          <a href="#" class="dropdown-item logout-item">🚪 Logout</a>
        </div>
      </div>
    </div>
  </header>

  <div class="layout layout-2col">
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">
        <a href="/" class="sidebar-link">
          <span class="sidebar-icon">🏠</span> Home
        </a>
        <a href="/groups" class="sidebar-link">
          <span class="sidebar-icon">👥</span> Groups
        </a>
        <a href="/interest-groups" class="sidebar-link">
          <span class="sidebar-icon">✨</span> Interest Groups
        </a>
        <a href="/forum" class="sidebar-link">
          <span class="sidebar-icon">💬</span> Forum
        </a>
        <a href="/ccas" class="sidebar-link active">
          <span class="sidebar-icon">🎭</span> CCAs
        </a>
        <a href="/students" class="sidebar-link">
          <span class="sidebar-icon">🔎</span> Student Finder
        </a>
        <a href="/groups?mine=1" class="sidebar-link">
          <span class="sidebar-icon">📌</span> My Groups
        </a>
        <a href="/profile" class="sidebar-link">
          <span class="sidebar-icon">🙍</span> My Profile
        </a>
      </nav>
    </aside>

    <main class="feed">
      <h1 class="feed-title">Add New CCA</h1>

      <section class="feed-section">
        <div class="card">
          <form id="ccaForm" class="cca-form">
            <div id="formError" class="form-error" style="display:none;"></div>

            <div class="form-group">
              <label class="form-label" for="cca_name">CCA Name <span style="color:#e11d48;">*</span></label>
              <input class="form-input" type="text" id="cca_name" name="cca_name" required />
            </div>

            <div class="form-group">
              <label class="form-label" for="category">Category <span style="color:#e11d48;">*</span></label>
              <select class="form-input" id="category" name="category" required>
                <option value="">Select a category</option>
                <option value="Technology">Technology</option>
                <option value="Arts">Arts</option>
                <option value="Sports">Sports</option>
                <option value="Student Life">Student Life</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="description">Description</label>
              <textarea class="form-textarea" id="description" name="description" rows="3"></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="training_day">Training Day</label>
              <input class="form-input" type="text" id="training_day" name="training_day" placeholder="e.g. Wednesday" />
            </div>

            <div class="form-group">
              <label class="form-label" for="training_time">Training Time</label>
              <input class="form-input" type="text" id="training_time" name="training_time" placeholder="e.g. 14:00 – 16:30 or 1pm – 3pm" />
            </div>

            <div class="form-group">
              <label class="form-label" for="location">Location</label>
              <input class="form-input" type="text" id="location" name="location" placeholder="e.g. Lab B1-03" />
            </div>

            <div class="form-group">
              <label class="form-label" for="contact_information">Contact Information</label>
              <input class="form-input" type="text" id="contact_information" name="contact_information" placeholder="e.g. Dr. Tan — tan@rp.edu.sg" />
            </div>

            <div class="form-group">
              <label class="form-label" for="image_url">Banner Image URL</label>
              <input class="form-input" type="url" id="image_url" name="image_url" placeholder="https://example.com/image.jpg" />
            </div>

            <div class="form-group" style="background:rgba(42,42,58,0.35); padding:12px; border-radius:8px; border:1px dashed var(--border);">
              <label class="form-label" style="color:var(--text-muted);">🖼️ Banner image</label>
              <p class="card-content" style="margin-bottom:0;">Deprecated: CCA banners are now auto-generated from the category using a gradient and tabler icon.</p>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Create CCA</button>
              <a href="/ccas" class="btn btn-outline">Cancel</a>
            </div>
          </form>
        </div>
      </section>
    </main>
  </div>

  <script src="/js/config.js"></script>
  <script src="/js/nav.js"></script>
  <script src="/js/ccaCreate.js"></script>
</body>
</html>
