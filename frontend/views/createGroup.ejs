<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect - Create Group</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="navbar">
    <div class="navbar-left">
      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">☰</button>
      <a href="/" class="logo">🎓 RPConnect</a>
    </div>

    <form class="navbar-search" action="#" method="GET" onsubmit="return false;">
      <span class="search-icon">🔍</span>
      <input type="text" name="q" placeholder="Search students, questions, groups..." />
    </form>

    <div class="navbar-right">
      <button class="btn btn-primary create-btn">+ Create</button>

      <button class="icon-btn notif-btn" aria-label="Notifications" title="Notifications">
        🔔
        <span class="notif-dot" id="notifDot" hidden></span>
      </button>

      <div class="navbar-profile dropdown">
        <button class="navbar-profile-trigger" id="profileMenuBtn">
          <div class="avatar avatar-sm" id="navAvatar"></div>
          <span class="navbar-username" id="navUsername"></span>
          <span class="caret">▾</span>
        </button>
        <div class="dropdown-menu" id="profileMenu">
          <a href="/profile" class="dropdown-item">🙍 My Profile</a>
          <a href="/profile" class="dropdown-item">⚙️ Settings</a>
          <a href="#" class="dropdown-item logout-item">🚪 Logout</a>
        </div>
      </div>
    </div>
  </header>

  <div class="layout layout-2col">
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">
        <a href="/" class="sidebar-link">
          <span class="sidebar-icon">🏠</span> Home
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">❓</span> Questions
        </a>
        <a href="/groups" class="sidebar-link active">
          <span class="sidebar-icon">👥</span> Groups
        </a>
        <a href="/ccas" class="sidebar-link">
          <span class="sidebar-icon">🎭</span> CCAs
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">🗓️</span> Timetables
        </a>
        <a href="/students" class="sidebar-link">
          <span class="sidebar-icon">🔎</span> Student Finder
        </a>
        <a href="/groups?mine=1" class="sidebar-link">
          <span class="sidebar-icon">📌</span> My Groups
        </a>
        <a href="/profile" class="sidebar-link">
          <span class="sidebar-icon">🙍</span> My Profile
        </a>
      </nav>
    </aside>

    <main class="feed">
      <h1 class="feed-title">Create a Group</h1>
      <p style="font-size:14px; color:var(--text-muted); margin-top:-4px;">Start a circle for your class, study buddies, CCA mates or friends.</p>

      <section class="feed-section">
        <div class="card">
          <form id="groupForm">
            <div id="formError" class="form-error" style="display:none;"></div>

            <div class="form-group">
              <label class="form-label" for="group_name">Group Name <span style="color:#e11d48;">*</span></label>
              <input class="form-input" type="text" id="group_name" name="group_name" maxlength="150" required placeholder="e.g. DIT E36A Class Group" />
            </div>

            <div class="form-group">
              <label class="form-label" for="group_type">Group Type <span style="color:#e11d48;">*</span></label>
              <select class="form-input" id="group_type" name="group_type" required>
                <option value="">Select a type</option>
                <option value="class">Class Group</option>
                <option value="study">Study Group</option>
                <option value="cca">CCA Group</option>
                <option value="interest">Interest Group</option>
                <option value="friend">Friend Group</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="description">Description</label>
              <textarea class="form-textarea" id="description" name="description" rows="3" placeholder="What is this group about?"></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="privacy">Privacy</label>
              <select class="form-input" id="privacy" name="privacy">
                <option value="public">Public — anyone can join instantly</option>
                <option value="private">Private — students must request to join</option>
              </select>
              <p class="form-hint">Private groups let you approve or reject join requests.</p>
            </div>

            <div class="search-filters" style="align-items:start;">
              <div class="form-group">
                <label class="form-label" for="diploma">Diploma</label>
                <input class="form-input" type="text" id="diploma" name="diploma" maxlength="150" placeholder="e.g. Information Technology" />
              </div>
              <div class="form-group">
                <label class="form-label" for="class_code">Class Code</label>
                <input class="form-input" type="text" id="class_code" name="class_code" maxlength="30" placeholder="e.g. E36A" />
              </div>
              <div class="form-group">
                <label class="form-label" for="module_code">Module Code</label>
                <input class="form-input" type="text" id="module_code" name="module_code" maxlength="20" placeholder="e.g. C237" />
              </div>
            </div>

            <div class="search-filters" style="align-items:start;">
              <div class="form-group">
                <label class="form-label" for="year_of_study">Year of Study</label>
                <select class="form-input" id="year_of_study" name="year_of_study">
                  <option value="">Any</option>
                  <option value="1">Year 1</option>
                  <option value="2">Year 2</option>
                  <option value="3">Year 3</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="semester">Semester</label>
                <select class="form-input" id="semester" name="semester">
                  <option value="">Any</option>
                  <option value="1">Semester 1</option>
                  <option value="2">Semester 2</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="max_members">Max Members</label>
                <input class="form-input" type="number" id="max_members" name="max_members" min="2" placeholder="No limit" />
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Create Group</button>
              <a href="/groups" class="btn btn-outline">Cancel</a>
            </div>
          </form>
        </div>
      </section>
    </main>
  </div>

  <script>
    window.CURRENT_USER = <%- JSON.stringify(user || null).replace(/</g, '\\u003c') %>;
  </script>
  <script src="/js/config.js"></script>
  <script src="/js/nav.js"></script>
  <script src="/js/groupForm.js"></script>
</body>
</html>
