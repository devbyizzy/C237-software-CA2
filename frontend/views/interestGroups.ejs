<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect - Interest Groups</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="navbar">
    <div class="navbar-left">
      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">☰</button>
      <a href="/" class="logo">🎓 RPConnect</a>
    </div>

    <form class="navbar-search" action="#" method="GET" onsubmit="return false;">
      <span class="search-icon">🔍</span>
      <input type="text" name="q" placeholder="Search students, questions, groups..." />
    </form>

    <div class="navbar-right">
      <button class="icon-btn notif-btn" aria-label="Notifications" title="Notifications">🔔</button>
      <div class="navbar-profile dropdown">
        <button class="navbar-profile-trigger" id="profileMenuBtn">
          <div class="avatar avatar-sm" id="navAvatar"></div>
          <span class="navbar-username" id="navUsername"></span>
          <span class="caret">▾</span>
        </button>
        <div class="dropdown-menu" id="profileMenu">
          <a href="/profile" class="dropdown-item">🙍 My Profile</a>
          <a href="#" class="dropdown-item logout-item">🚪 Logout</a>
        </div>
      </div>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">
        <a href="/" class="sidebar-link"><span class="sidebar-icon">🏠</span> Home</a>
        <a href="/groups" class="sidebar-link"><span class="sidebar-icon">👥</span> Groups</a>
        <a href="/interest-groups" class="sidebar-link active"><span class="sidebar-icon">✨</span> Interest Groups</a>
        <a href="/profile" class="sidebar-link"><span class="sidebar-icon">🙍</span> My Profile</a>
      </nav>
    </aside>

    <main class="feed">
      <h1 class="feed-title">✨ Interest Groups</h1>
      <p style="font-size:14px; color:var(--text-muted); margin-top:-4px;">
        Groups built around a shared hobby or interest, not a class or module.
      </p>

      <section class="feed-section">
        <div class="card">
          <h2 style="margin-top:0;" id="formTitle">Create an Interest Group</h2>
          <div id="formError" class="form-error" style="display:none;"></div>

          <form id="interestGroupForm">
            <input type="hidden" id="editingId" value="" />

            <div class="form-group">
              <label class="form-label" for="group_name">Group Name <span style="color:#e11d48;">*</span></label>
              <input class="form-input" type="text" id="group_name" name="group_name" maxlength="150" required placeholder="e.g. Badminton Buddies" />
            </div>

            <div class="form-group">
              <label class="form-label" for="description">Description</label>
              <textarea class="form-textarea" id="description" name="description" rows="3" placeholder="What is this group about?"></textarea>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary" id="submitBtn">Create Group</button>
              <button type="button" class="btn btn-outline" id="cancelEditBtn" style="display:none;">Cancel Edit</button>
            </div>
          </form>
        </div>
      </section>

      <section class="feed-section">
        <div class="card">
          <form id="filterForm" class="search-filters">
            <div class="form-group" style="margin-bottom:0; grid-column:1 / -1;">
              <label class="form-label" for="searchInput">Search</label>
              <input class="form-input" type="text" id="searchInput" placeholder="Search interest groups..." />
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="sortSelect">Sort By</label>
              <select class="form-input" id="sortSelect">
                <option value="newest">Newest first</option>
                <option value="oldest">Oldest first</option>
                <option value="name">Name (A–Z)</option>
              </select>
            </div>
            <div class="form-actions" style="margin-top:0;">
              <button type="submit" class="btn btn-primary">Search</button>
            </div>
          </form>
        </div>
      </section>

      <section class="feed-section">
        <p class="results-count" id="resultsCount"></p>
        <div class="search-results-grid" id="groupResults"></div>
      </section>
    </main>
  </div>

  <script>
    window.CURRENT_USER = <%- JSON.stringify(user || null).replace(/</g, '\\u003c') %>;
  </script>
  <script src="/js/config.js"></script>
  <script src="/js/nav.js"></script>
  <script src="/js/interestGroups.js"></script>
</body>
</html>
