<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RPConnect - CCAs</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="navbar">
    <div class="navbar-left">
      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">☰</button>
      <a href="/" class="logo">🎓 RPConnect</a>
    </div>

    <form class="navbar-search" action="#" method="GET" onsubmit="return false;">
      <span class="search-icon">🔍</span>
      <input type="text" name="q" placeholder="Search students, questions, groups..." />
    </form>

    <div class="navbar-right">
      <button class="btn btn-primary create-btn">+ Create</button>

      <button class="icon-btn notif-btn" aria-label="Notifications" title="Notifications">
        🔔
        <span class="notif-dot" id="notifDot" hidden></span>
      </button>

      <div class="navbar-profile dropdown">
        <button class="navbar-profile-trigger" id="profileMenuBtn">
          <div class="avatar avatar-sm" id="navAvatar"></div>
          <span class="navbar-username" id="navUsername"></span>
          <span class="caret">▾</span>
        </button>
        <div class="dropdown-menu" id="profileMenu">
          <a href="/profile" class="dropdown-item">🙍 My Profile</a>
          <a href="/profile" class="dropdown-item">⚙️ Settings</a>
          <a href="#" class="dropdown-item logout-item">🚪 Logout</a>
        </div>
      </div>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">
        <a href="/" class="sidebar-link">
          <span class="sidebar-icon">🏠</span> Home
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">❓</span> Questions
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">👥</span> Groups
        </a>
        <a href="/ccas" class="sidebar-link active">
          <span class="sidebar-icon">🎭</span> CCAs
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">🗓️</span> Timetables
        </a>
        <a href="/students" class="sidebar-link">
          <span class="sidebar-icon">🔎</span> Student Finder
        </a>
        <a href="#" class="sidebar-link">
          <span class="sidebar-icon">📌</span> My Groups
        </a>
        <a href="/profile" class="sidebar-link">
          <span class="sidebar-icon">🙍</span> My Profile
        </a>
      </nav>
    </aside>

    <main class="feed">
      <h1 class="feed-title">CCA Directory</h1>

      <section class="feed-section">
        <div class="card">
          <form id="searchForm" class="search-filters">
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="searchInput">Search CCA</label>
              <input class="form-input" type="text" id="searchInput" name="search" placeholder="e.g. Robotics" />
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label" for="categorySelect">Category</label>
              <select class="form-input" id="categorySelect" name="category">
                <option value="">All Categories</option>
                <option value="Technology">Technology</option>
                <option value="Arts">Arts</option>
                <option value="Sports">Sports</option>
                <option value="Student Life">Student Life</option>
              </select>
            </div>
            <div class="form-actions" style="margin-top:0;">
              <button type="submit" class="btn btn-primary">Search</button>
              <button type="button" id="clearFiltersBtn" class="btn btn-outline">Clear</button>
            </div>
          </form>
        </div>
      </section>

      <section class="feed-section">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <p class="results-count" id="resultsCount"></p>
          <a href="/admin/ccas/add" class="btn btn-primary">+ Add CCA</a>
        </div>
        <div class="search-results-grid" id="ccaResults"></div>
      </section>
    </main>

    <aside class="right-panel">
      <section class="panel-section">
        <h2>🎭 About CCAs</h2>
        <p style="font-size:13px; color:var(--text-muted); line-height:1.6;">
          Co-Curricular Activities (CCAs) are an important part of student life at RP.
          Browse available CCAs, find session times, and get involved!
        </p>
      </section>
    </aside>
  </div>

  <script src="/js/config.js"></script>
  <script src="/js/nav.js"></script>
  <script src="/js/ccas.js"></script>
</body>
</html>
