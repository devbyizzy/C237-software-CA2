<%- include('partials/header') %>

<%
  function timeAgo(dateStr) {
    const diffMs = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diffMs / 60000);
    if (mins < 60) return mins + 'm ago';
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return hrs + 'h ago';
    const days = Math.floor(hrs / 24);
    return days + 'd ago';
  }
%>

<%- include('partials/navbar') %>

<div class="layout">
  <%- include('partials/sidebar') %>

  <main class="feed">
    <h1 class="feed-title">Welcome back, <%= currentProfile.display_name %> 👋</h1>

    <section class="feed-section">
      <div class="feed-section-header">
        <h2>Latest Questions</h2>
        <a href="/questions" class="see-all">See all</a>
      </div>
      <% latestQuestions.forEach(function(q) { %>
        <article class="card question-card">
          <div class="card-top">
            <span class="badge"><%= q.category %></span>
            <span class="card-date"><%= timeAgo(q.created_at) %></span>
          </div>
          <h3 class="card-title"><%= q.title %></h3>
          <p class="card-content"><%= q.content %></p>
          <div class="card-footer">
            <span class="card-author">by <%= q.author_name %></span>
            <div class="card-actions">
              <button class="action-btn upvote-btn" data-count="<%= q.upvotes %>">
                ⬆️ <span class="count"><%= q.upvotes %></span>
              </button>
              <button class="action-btn">💬 <%= q.comments %></button>
            </div>
          </div>
        </article>
      <% }) %>
    </section>

    <section class="feed-section">
      <div class="feed-section-header">
        <h2>New Groups</h2>
        <a href="/groups" class="see-all">See all</a>
      </div>
      <% newGroups.forEach(function(g) { %>
        <article class="card group-card">
          <h3 class="card-title"><%= g.group_name %></h3>
          <p class="card-content"><%= g.description %></p>
          <div class="card-footer">
            <span class="card-author">created by <%= g.creator_name %></span>
            <button class="btn btn-outline join-btn">Join</button>
          </div>
        </article>
      <% }) %>
    </section>

    <section class="feed-section">
      <div class="feed-section-header">
        <h2>CCA Announcements</h2>
        <a href="/ccas" class="see-all">See all</a>
      </div>
      <% ccaAnnouncements.forEach(function(c) { %>
        <article class="card cca-card">
          <div class="card-top">
            <span class="badge">🎭 <%= c.category %></span>
            <span class="card-date"><%= timeAgo(c.created_at) %></span>
          </div>
          <h3 class="card-title"><%= c.cca_name %></h3>
          <p class="card-content"><%= c.description %></p>
        </article>
      <% }) %>
    </section>

    <section class="feed-section">
      <div class="feed-section-header">
        <h2>Shared Timetables</h2>
        <a href="/timetables" class="see-all">See all</a>
      </div>
      <% sharedTimetables.forEach(function(t) { %>
        <article class="card timetable-card">
          <div class="card-top">
            <span class="badge">🗓️ <%= t.class_code %></span>
            <span class="card-date"><%= timeAgo(t.shared_at) %></span>
          </div>
          <h3 class="card-title"><%= t.title %></h3>
          <p class="card-content"><%= t.diploma %></p>
          <div class="card-footer">
            <span class="card-author">shared by <%= t.owner_name %></span>
            <button class="btn btn-outline view-btn">View</button>
          </div>
        </article>
      <% }) %>
    </section>
  </main>

  <aside class="right-panel">
    <section class="panel-section">
      <h2>🔥 Trending Questions</h2>
      <% trendingQuestions.forEach(function(q) { %>
        <div class="mini-card">
          <p class="mini-title"><%= q.title %></p>
          <span class="mini-meta"><%= q.upvotes %> upvotes · <%= q.comments %> comments</span>
        </div>
      <% }) %>
    </section>

    <section class="panel-section">
      <h2>👥 Popular Groups</h2>
      <% popularGroups.forEach(function(g) { %>
        <div class="mini-card">
          <p class="mini-title"><%= g.group_name %></p>
          <span class="mini-meta"><%= g.member_count %> members</span>
        </div>
      <% }) %>
    </section>

    <section class="panel-section">
      <h2>🎭 Recommended CCAs</h2>
      <% recommendedCcas.forEach(function(c) { %>
        <div class="mini-card">
          <p class="mini-title"><%= c.cca_name %></p>
          <span class="mini-meta"><%= c.category %></span>
        </div>
      <% }) %>
    </section>

    <section class="panel-section">
      <h2>✨ Suggested Students</h2>
      <% suggestedStudents.forEach(function(s) { %>
        <div class="mini-card student-suggestion">
          <div class="avatar avatar-sm"><%= s.display_name.charAt(0).toUpperCase() %></div>
          <div>
            <p class="mini-title"><%= s.display_name %></p>
            <span class="mini-meta"><%= s.diploma %></span>
          </div>
        </div>
      <% }) %>
    </section>
  </aside>
</div>

<%- include('partials/footer') %>
