<%# editGroup.ejs - the "U" in CRUD. Prefilled with the group row from
    GET /groups/:id/edit and submits to POST /groups/:id/edit. %>
<%- include('partials/header', { title: 'Edit ' + group.group_name }) %>

<section>
    <h2>Edit Group</h2>

    <form method="POST" action="/groups/<%= group.group_id %>/edit" class="stacked-form">
        <label for="group_name">Group name *</label>
        <input type="text" id="group_name" name="group_name" required maxlength="100"
               value="<%= group.group_name %>">

        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3"><%= group.description %></textarea>

        <label for="group_type">Group type *</label>
        <select id="group_type" name="group_type" required>
            <% groupTypes.forEach(type => { %>
                <option value="<%= type %>" <%= group.group_type === type ? 'selected' : '' %>>
                    <%= type %> Group
                </option>
            <% }) %>
        </select>

        <fieldset>
            <legend>Class / module details (optional)</legend>

            <label for="diploma">Diploma</label>
            <input type="text" id="diploma" name="diploma" value="<%= group.diploma || '' %>">

            <label for="class_code">Class code</label>
            <input type="text" id="class_code" name="class_code" maxlength="20"
                   value="<%= group.class_code || '' %>">

            <label for="module_code">Module code</label>
            <input type="text" id="module_code" name="module_code" maxlength="20"
                   value="<%= group.module_code || '' %>">

            <label for="year_of_study">Year of study</label>
            <input type="number" id="year_of_study" name="year_of_study" min="1" max="3"
                   value="<%= group.year_of_study || '' %>">

            <label for="semester">Semester</label>
            <input type="number" id="semester" name="semester" min="1" max="2"
                   value="<%= group.semester || '' %>">
        </fieldset>

        <fieldset>
            <legend>Privacy *</legend>
            <label>
                <input type="radio" name="privacy" value="public"
                       <%= group.privacy === 'public' ? 'checked' : '' %>>
                Public - anyone can join instantly
            </label>
            <label>
                <input type="radio" name="privacy" value="private"
                       <%= group.privacy === 'private' ? 'checked' : '' %>>
                Private - the owner must approve join requests
            </label>
        </fieldset>

        <label for="maximum_members">Maximum members</label>
        <input type="number" id="maximum_members" name="maximum_members" min="2"
               value="<%= group.maximum_members %>">

        <button type="submit">Save Changes</button>
        <a href="/groups/<%= group.group_id %>">Cancel</a>
    </form>
</section>

<%- include('partials/footer') %>
