+<%# groups.ejs - browse/search page. Data comes from GET /groups:
+    groups (rows + member_count), groupTypes, diplomas, filters %>
+<%- include('partials/header', { title: 'Browse Groups' }) %>
+
+<section class="page-intro">
+    <h2>RP Circles</h2>
+    <p>Find your classmates, study buddies and friends across RP.</p>
+</section>
+
+<%# Search/filter form: submits back to GET /groups as a query string %>
+<section aria-label="Search groups">
+    <form method="GET" action="/groups" class="filter-bar">
+        <input type="text" name="q" placeholder="Search by name, description or module"
+               value="<%= filters.q %>">
+
+        <%# Dropdown options come from the server, not hardcoded here %>
+        <select name="type">
+            <option value="">All types</option>
+            <% groupTypes.forEach(type => { %>
+                <option value="<%= type %>" <%= filters.type === type ? 'selected' : '' %>>
+                    <%= type %> Group
+                </option>
+            <% }) %>
+        </select>
+
+        <%# Diploma options are DISTINCT values already stored in the database %>
+        <select name="diploma">
+            <option value="">All diplomas</option>
+            <% diplomas.forEach(dip => { %>
+                <option value="<%= dip %>" <%= filters.diploma === dip ? 'selected' : '' %>>
+                    <%= dip %>
+                </option>
+            <% }) %>
+        </select>
+
+        <button type="submit">Search</button>
+        <a href="/groups">Clear</a>
+    </form>
+</section>
+
+<%# Results list: one <article> card per group row from the database %>
+<section aria-label="Group results">
+    <% if (groups.length === 0) { %>
+        <p>No groups match your search. <a href="/groups/create">Create the first one!</a></p>
+    <% } %>
+
+    <% groups.forEach(group => { %>
+        <article class="group-card">
+            <h3><a href="/groups/<%= group.group_id %>"><%= group.group_name %></a></h3>
+            <p class="meta">
+                <span class="tag"><%= group.group_type %> Group</span>
+                <span class="tag"><%= group.privacy %></span>
+                <% if (group.diploma) { %><span class="tag"><%= group.diploma %></span><% } %>
+                <% if (group.class_code) { %><span class="tag">Class <%= group.class_code %></span><% } %>
+                <% if (group.module_code) { %><span class="tag"><%= group.module_code %></span><% } %>
+            </p>
+            <p><%= group.description %></p>
+            <p class="meta"><%= group.member_count %> / <%= group.maximum_members %> members</p>
+        </article>
+    <% }) %>
+</section>
+
+<%- include('partials/footer') %>
