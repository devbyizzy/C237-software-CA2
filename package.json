{
  "name": "rpconnect",
  "version": "1.0.0",
  "description": "RPConnect full-stack application",
  "private": true,
  "scripts": {
    "install-all": "npm install --prefix backend && npm install --prefix frontend",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm start --prefix frontend",
    "dev": "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" \"npm run backend\" \"npm run frontend\"",
    "start": "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" \"npm start --prefix backend\" \"npm start --prefix frontend\"",
    "postinstall": "npm run install-all"
  },
  "dependencies": {
    "concurrently": "^9.2.4"
  }
}
